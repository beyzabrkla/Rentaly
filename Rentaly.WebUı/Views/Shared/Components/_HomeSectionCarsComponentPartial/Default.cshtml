@model IEnumerable<Car>
<section id="section-cars">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 offset-lg-3 text-center">
                <h2>Araç Filomuz</h2>
                <p>Hayallerinizi gerçeğe dönüştüren, unutulmaz yolculuklar için seçkin ve çok yönlü araç filomuzu keşfedin.</p>
                <div class="spacer-20"></div>
            </div>
        </div>
    </div>
    <div class="container-fluid">
        <div class="row align-items-center">
            <div id="items-carousel-alt-2" class="owl-carousel wow fadeIn">

                @foreach (var car in Model)
                {
                    <div class="col-lg-12">
                        <div class="de-item alt-2 mb30">
                            <div class="d-img">
                                <img src="@car.CoverImageUrl" class="img-fluid" alt="@car.Brand?.BrandName @car.CarModel?.ModelName">
                            </div>
                            <div class="d-info">
                                <div class="d-text">
                                    <h4>@car.Brand?.BrandName @car.CarModel?.ModelName</h4>
                                    <div class="d-atr-group">
                                        <span class="d-atr"><img src="/RentalyHTML/images/icons/1-green.svg" alt="">@car.SeatCount</span>
                                        <span class="d-atr"><img src="/RentalyHTML/images/icons/2-green.svg" alt="">@car.PersonCount</span>
                                        <span class="d-atr"><img src="/RentalyHTML/images/icons/3-green.svg" alt="">@car.LuggageCount</span>
                                        <span class="d-atr"><img src="/RentalyHTML/images/icons/4-green.svg" alt="">@car.Category?.CategoryName</span>
                                    </div>
                                    <div class="d-price">
                                        Günlük kira bedeli: <span>₺ @car.DailyPrice.ToString("N0")</span>'den başlayan fiyatlarla
                                        <a class="btn-main" href="/Car/CarDetail/@car.CarId">Hemen Kirala</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }

            </div>
        </div>
    </div>
</section>

<style>
    /* Resimlerin hepsini aynı boyuta getirir ve kesilmesini engeller */
.de-item.alt-2 .d-img {
    height: 220px; /* İstediğin yüksekliği buraya yaz */
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
}

.de-item.alt-2 .d-img img {
    height: 100%;
    width: 100%;
    object-fit: contain; /* Resmi bozmadan kutuya sığdırır */
    padding: 15px; /* Resmin etrafında biraz boşluk bırakır */
}

/* Kartın alt kısmının da eşit hizalanması için */
.de-item.alt-2 {
    display: flex;
    flex-direction: column;
    height: 100%; /* Tüm kartların aynı yükseklikte olmasını sağlar */
}

.de-item.alt-2 .d-info {
    flex-grow: 1; /* İçeriği kartın kalan kısmına yayar */
        }
        /* Resimlerin hepsini aynı boyuta getirir ve kesilmesini engeller */
        .de-item.alt-2 .d-img {
            height: 220px; /* İstediğin yüksekliği buraya yaz */
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }

            .de-item.alt-2 .d-img img {
                height: 100%;
                width: 100%;
                object-fit: contain; /* Resmi bozmadan kutuya sığdırır */
                padding: 15px; /* Resmin etrafında biraz boşluk bırakır */
            }

    /* Kartın alt kısmının da eşit hizalanması için */
    .de-item.alt-2 {
        display: flex;
        flex-direction: column;
        height: 100%; /* Tüm kartların aynı yükseklikte olmasını sağlar */
    }

        .de-item.alt-2 .d-info {
            flex-grow: 1; /* İçeriği kartın kalan kısmına yayar */
        }
</style>