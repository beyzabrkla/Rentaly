<div class="quick-modal-backdrop" id="modal-category">
    <div class="quick-modal">
        <div class="quick-modal-title"><i class="fa-solid fa-tags"></i> Yeni Kategori Ekle</div>
        <label class="form-label" for="qCategoryName">Kategori Adı <span class="required">*</span></label>
        <input type="text" id="qCategoryName" class="form-control" placeholder="Örn: Cabrio" maxlength="100" />
        <div class="quick-modal-error" id="qCategoryError"></div>
        <div class="quick-modal-footer">
            <button type="button" class="btn-modal-cancel" onclick="closeModal('category')">İptal</button>
            <button type="button" class="btn-modal-save" id="qCategorySaveBtn" onclick="quickSave('category')"><i class="fa-solid fa-check"></i> Kaydet</button>
        </div>
    </div>
</div>