<div class="quick-modal-backdrop" id="modal-brand">
    <div class="quick-modal">
        <div class="quick-modal-title"><i class="fa-solid fa-trademark"></i> Yeni Marka Ekle</div>
        <label class="form-label" for="qBrandName">Marka Adı <span class="required">*</span></label>
        <input type="text" id="qBrandName" class="form-control" placeholder="Örn: Skoda" maxlength="100" />
        <div class="quick-modal-error" id="qBrandError"></div>
        <div class="quick-modal-footer">
            <button type="button" class="btn-modal-cancel" onclick="closeModal('brand')">İptal</button>
            <button type="button" class="btn-modal-save" id="qBrandSaveBtn" onclick="quickSave('brand')"><i class="fa-solid fa-check"></i> Kaydet</button>
        </div>
    </div>
</div>