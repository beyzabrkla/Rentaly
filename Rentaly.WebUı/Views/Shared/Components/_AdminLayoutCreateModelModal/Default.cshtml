<div class="quick-modal-backdrop" id="modal-model">
    <div class="quick-modal">
        <div class="quick-modal-title"><i class="fa-solid fa-cube"></i> Yeni Model Ekle</div>
        <label class="form-label">Marka</label>
        <div id="qModelBrandInfo" style="font-size:13px;color:var(--text-muted);margin-bottom:14px;padding:8px 12px;background:#2a2a2a;border-radius:var(--radius-sm);"></div>
        <label class="form-label" for="qModelName">Model Adı <span class="required">*</span></label>
        <input type="text" id="qModelName" class="form-control" placeholder="Örn: Octavia" maxlength="100" />
        <div class="quick-modal-error" id="qModelError"></div>
        <div class="quick-modal-footer">
            <button type="button" class="btn-modal-cancel" onclick="closeModal('model')">İptal</button>
            <button type="button" class="btn-modal-save" id="qModelSaveBtn" onclick="quickSave('model')"><i class="fa-solid fa-check"></i> Kaydet</button>
        </div>
    </div>
</div>