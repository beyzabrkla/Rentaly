@model Rentaly.EntityLayer.Entities.Banner
@using Rentaly.EntityLayer.Entities
@{
    var categories = ViewBag.Categories as List<Category> ?? new List<Category>();
    var branches = ViewBag.Branches as List<Branch> ?? new List<Branch>();
}

<section id="section-hero" aria-label="section" class="jarallax full-height vertical-center">
    <img src="@(Model?.BackgroundImageUrl ?? "/RentalyHTML/images/background/1.jpg")" class="jarallax-img" alt="">
    
    <div class="container position-relative z1000">
        <div class="row align-items-center">
            <div class="col-lg-6 text-light">
                <h4><span class="id-color">@(Model?.SubTitle ?? "Araç Kiralamanın Hızlı ve Kolay Yolu")</span></h4>
                <div class="spacer-10"></div>
                <h1 class="mb-2">@(Model?.Title ?? "Dünyayı konforlu araçlarımızla keşfedin")</h1>
                <div class="spacer-10"></div>
                <p class="lead">@(Model?.Description ?? "Olağanüstü konforlu ve şık araç filomuzla unutulmaz maceralara atılın.")</p>
            </div>

            <div class="col-lg-6">
                <div class="spacer-single sm-hide"></div>
                <div class="p-4 rounded-3 shadow-soft text-light" data-bgcolor="rgba(0, 0, 0, .6)">

                    <form id='search_form' method="get" action="/Car/CarList">
                        <h5>Araç tipiniz nedir?</h5>
                        
                        <div class="category-scroll-container custom-scroll">
                            @foreach (var category in categories)
                            {
                                <div class="radio-img-item">
                                    <input id="radio-cat-@category.CategoryId" name="category" type="radio" value="@category.CategoryName"
                                    @(categories.IndexOf(category) == 0 ? "checked" : "")>
                                    <label for="radio-cat-@category.CategoryId">
                                        <img src="@(category.IconUrl ?? "/RentalyHTML/images/select-form/car.png")" alt="@category.CategoryName">
                                        <span>@category.CategoryName</span>
                                    </label>
                                </div>
                            }
                        </div>

                        <div class="spacer-20"></div>

                        <div class="row">
                            <div class="col-lg-6 mb20">
                                <h5>Alış Yeri</h5>
                                <select name="branch" class="form-control" required>
                                    <option value="">Konum seçin</option>
                                    @foreach (var branch in branches.Where(x => x.IsActive)) 
                                    {
                                        <option value="@branch.BranchId">@branch.BranchName - @branch.City</option>
                                    }
                                </select>
                            </div>

                            <div class="col-lg-6 mb20">
                                <h5>Dönüş Yeri</h5>
                                <select name="dropoffLocationId" class="form-control">
                                    <option value="">Aynı Şube</option>
                                    @foreach (var branch in branches.Where(x => x.IsActive))
                                    {
                                        <option value="@branch.BranchId">@branch.BranchName - @branch.City</option>
                                    }
                                </select>
                            </div>
                            <div class="col-lg-6 mb20">
                                <h5>Alış Tarihi</h5>
                                <div class="date-time-field">
                                    <input type="text" id="pickupDate" name="pickupDate" class="form-control date-picker-control" placeholder="Tarih seçin..." required readonly>
                                </div>
                            </div>

                            <div class="col-lg-6 mb20">
                                <h5>Dönüş Tarihi</h5>
                                <div class="date-time-field">
                                    <input type="text" id="dropOffDate" name="dropOffDate" class="form-control date-picker-control" placeholder="Tarih seçin..." required readonly>
                                </div>
                            </div>
                        </div>

                        <div class="spacer-20"></div>
                        <input type='submit' value='Araç Bul' class="btn-main pull-right">
                        <div class="clearfix"></div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/themes/dark.css"> <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script src="https://npmcdn.com/flatpickr/dist/l10n/tr.js"></script>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        // Flatpickr ayarları
        const config = {
            locale: "tr",
            minDate: "today",
            dateFormat: "Y-m-d", 
            disableMobile: "true", 
            allowInput: false
        };

        const pickUp = flatpickr("#pickupDate", config);
        const dropOff = flatpickr("#dropOffDate", config);

        // Alış tarihi değiştiğinde dönüş tarihinin minimumunu güncelle
        document.getElementById("pickupDate").addEventListener("change", function(){
             dropOff.set("minDate", this.value);
        });
    });
</script>

<style>
    .flatpickr-calendar {
        z-index: 10000 !important;
    }
    
    .date-picker-control {
        background-color: #fff !important; 
        color: #000 !important;
        cursor: pointer !important;
    }

    .category-scroll-container {
        display: flex;
        overflow-x: auto;
        gap: 15px;
        padding-bottom: 10px;
        white-space: nowrap;
    }
    .radio-img-item { flex: 0 0 auto; width: 100px; text-align: center; }
    .radio-img-item input[type="radio"] { display: none; }
    .radio-img-item label {
        display: flex; flex-direction: column; align-items: center; padding: 10px;
        border: 2px solid #333; border-radius: 8px; cursor: pointer;
        background: rgba(0,0,0,0.3); transition: 0.3s;
    }
    .radio-img-item label img { height: 35px; margin-bottom: 5px; }
    .radio-img-item input[type="radio"]:checked + label {
        border-color: #cc0c0c; background: rgba(204, 12, 12, 0.2); color: #cc0c0c;
    }
    .custom-scroll::-webkit-scrollbar { height: 4px; }
    .custom-scroll::-webkit-scrollbar-thumb { background: #cc0c0c; border-radius: 10px; }
    .date-time-field { display: flex; gap: 5px; }
</style>