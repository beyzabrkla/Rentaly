<style>
    .badge-dot {
        width: 8px;
        height: 8px;
        background: #cc0c0c;
        border: 2px solid #111; /* Navbar renginde border ki iç içe geçmesin */
        border-radius: 50%;
        position: absolute;
        top: 10px;
        right: 10px;
        box-shadow: 0 0 10px rgba(204, 12, 12, 0.5);
    }

    /* Navbar Üst Bar Ayarları */
    .navbar-top {
        background: #111 !important; /* Sidebar ile birebir aynı derin siyah */
        height: 70px;
        display: flex;
        align-items: center;
        padding: 0 25px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05); /* Çok hafif bir ayrım çizgisi */
        position: sticky;
        top: 0;
        z-index: 999;
        transition: all 0.3s ease;
    }

    /* Breadcrumb (Yol Tarifi) Yazı Renkleri */
    .breadcrumb-item a {
        color: #b3b3b3 !important; /* Sidebar link rengiyle aynı */
        text-decoration: none;
        font-size: 14px;
    }

    .breadcrumb-item.active {
        color: #fff !important; /* Aktif sayfa bembeyaz */
        font-weight: 500;
    }

    /* Sağ taraftaki aksiyon butonları (Bildirim, Mesaj vb.) */
    .action-btn {
        background: rgba(255, 255, 255, 0.03); /* Hafif şeffaf arka plan */
        border: 1px solid rgba(255, 255, 255, 0.08);
        color: #b3b3b3;
        width: 40px;
        height: 40px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: 0.2s;
    }

        .action-btn:hover {
            background: rgba(204, 12, 12, 0.1); /* Rentaly kırmızısı hover */
            color: #cc0c0c;
            border-color: rgba(204, 12, 12, 0.2);
        }

    /* Admin İsim ve Rol Yazıları */
    .admin-name {
        color: #fff !important;
        font-weight: 500;
    }

    .admin-role {
        color: #888 !important;
        font-size: 11px;
    }

    /* Hamburger Menü Butonu */
    .toggle-btn {
        color: #fff;
        background: transparent;
        border: none;
        font-size: 20px;
        margin-right: 15px;
        cursor: pointer;
    }
</style>


<div class="main-wrapper" id="mainWrapper">
    <nav class="navbar-top" id="navbarTop">
        <button class="toggle-btn" id="toggleBtn" onclick="toggleSidebar()">
            <i class="fa-solid fa-bars"></i>
        </button>
        <div class="navbar-breadcrumb d-none d-sm-block">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/Admin/Dashboard/Index">Ana Sayfa</a></li>
        
                @if (ViewData["BreadcrumbParent"] != null)
                {
                    <li class="breadcrumb-item">
                        <a href="@ViewData["BreadcrumbParentUrl"]">@ViewData["BreadcrumbParent"]</a>
                    </li>
                }
        
                <li class="breadcrumb-item active">@ViewData["Title"]</li>
            </ol>
        </div>
        <div class="navbar-actions ms-auto">
            <div class="dropdown notif-dropdown">
                <button class="action-btn" data-bs-toggle="dropdown">
                    <i class="fa-regular fa-bell"></i><span class="badge-dot"></span>
                </button>
                <ul class="dropdown-menu dropdown-menu-end">
                    <div class="notif-header">
                        <h6>Bildirimler</h6>
                        <a href="#">Tümünü Gör</a>
                    </div>
                    <div class="notif-list">
                        <div class="notif-item">
                            <div class="notif-icon" style="background:rgba(204,12,12,0.15);color:var(--primary);">
                                <i class="fa-solid fa-calendar-check"></i>
                            </div>
                            <div class="notif-text">
                                <p>Yeni rezervasyon talebi alındı</p>
                                <small>2 dakika önce</small>
                            </div>
                        </div>
                        <div class="notif-item">
                            <div class="notif-icon" style="background:rgba(16,185,129,0.15);color:#10b981;">
                                <i class="fa-solid fa-credit-card"></i>
                            </div>
                            <div class="notif-text">
                                <p>₺4.200 ödeme alındı</p>
                                <small>3 saat önce</small>
                            </div>
                        </div>
                    </div>
                </ul>
            </div>
            <button class="action-btn"><i class="fa-regular fa-envelope"></i></button>
            <div class="navbar-divider d-none d-sm-block"></div>
            <div class="dropdown admin-dropdown">
                <a href="#" class="dropdown-toggle d-flex align-items-center gap-2" data-bs-toggle="dropdown">
                    <img src="https://ui-avatars.com/api/?name=Admin+User&background=cc0c0c&color=fff&size=80" alt="Admin">
                    <div class="admin-info d-none d-lg-flex">
                        <span class="admin-name">Admin User</span>
                        <span class="admin-role">Süper Yönetici</span>
                    </div>
                    <i class="fa-solid fa-chevron-down" style="font-size:11px;color:var(--text-muted);"></i>
                </a>
                <ul class="dropdown-menu dropdown-menu-end">
                    <li><a class="dropdown-item" href="#"><i class="fa-regular fa-user"></i> Profil</a></li>
                    <li><a class="dropdown-item" href="#"><i class="fa-solid fa-gear"></i> Ayarlar</a></li>
                    <li><hr class="dropdown-divider"></li>
                    <li><a class="dropdown-item text-danger" href="#"><i class="fa-solid fa-right-from-bracket"></i> Çıkış Yap</a></li>
                </ul>
            </div>
        </div>
    </nav>
