@model List<Testimonial>

<section id="section-testimonials" class="no-top no-bottom">
    <div class="container">
        <div class="row g-4 align-items-center">
            @{
                int count = 0;
            }
            @foreach (var item in Model)
            {
                <div class="col-md-4">
                    @for (int i = 0; i < count; i++)
                    {
                        <div class="spacer-double sm-hide"></div>
                    }
                    <div class="de-image-text">
                        <div class="d-text">
                            <div class="d-quote id-color"><i class="fa fa-quote-right"></i></div>
                            <h4>@item.Title</h4>
                            <blockquote>
                                @item.Comment
                                <span class="by">@item.Name</span>
                            </blockquote>
                        </div>
                        <img src="@item.ImageUrl" class="img-fluid" alt="@item.Name">
                    </div>
                </div>
                count++; 
            }
        </div>
    </div>
</section>