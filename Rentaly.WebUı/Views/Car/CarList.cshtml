@using Rentaly.EntityLayer.Entities
@using Microsoft.AspNetCore.WebUtilities
@model List<Car>
@{
    ViewData["Title"] = "CarList";
    Layout = "~/Views/Shared/_Layout.cshtml";

    // URL'den filter parametrelerini al
    string categoryFilter = Context.Request.Query["category"];
    string seatsFilter = Context.Request.Query["seats"];
    string fuelFilter = Context.Request.Query["fuel"];
    string branchFilter = Context.Request.Query["branch"];
    string searchFilter = Context.Request.Query["search"];
    string minPriceFilter = Context.Request.Query["minPrice"];
    string maxPriceFilter = Context.Request.Query["maxPrice"];
}

<section id="subheader" class="jarallax text-light">
    <img src="/RentalyHTML/images/background/2.jpg" class="jarallax-img" alt="">
    <div class="center-y relative text-center">
        <div class="container">
            <div class="row">
                <div class="col-md-12 text-center">
                    <h1>Araçlarımız</h1>
                </div>
                <div class="clearfix"></div>
            </div>
        </div>
    </div>
</section>

<section id="section-cars">
    <div class="container">
        <div class="row">
            <!-- Sol Filtreleme Paneli -->
            <div class="col-lg-3">
                <!-- Kategori Filtresi -->
                <div class="item_filter_group">
                    <h4>Kategori</h4>
                    <div class="de_form">
                        <div class="de_checkbox">
                            <input id="filter_all" name="filter_category" type="radio" value="0" @(string.IsNullOrEmpty(categoryFilter) ? "checked" : "") onchange="filterCars()">
                            <label for="filter_all">Tüm Araçlar</label>
                        </div>
                        <div class="de_checkbox">
                            <input id="filter_sedan" name="filter_category" type="radio" value="sedan" @(categoryFilter == "sedan" ? "checked" : "") onchange="filterCars()">
                            <label for="filter_sedan">Sedan</label>
                        </div>
                        <div class="de_checkbox">
                            <input id="filter_suv" name="filter_category" type="radio" value="suv" @(categoryFilter == "suv" ? "checked" : "") onchange="filterCars()">
                            <label for="filter_suv">SUV</label>
                        </div>
                        <div class="de_checkbox">
                            <input id="filter_hatchback" name="filter_category" type="radio" value="hatchback" @(categoryFilter == "hatchback" ? "checked" : "") onchange="filterCars()">
                            <label for="filter_hatchback">Hatchback</label>
                        </div>
                        <div class="de_checkbox">
                            <input id="filter_coupe" name="filter_category" type="radio" value="coupe" @(categoryFilter == "coupe" ? "checked" : "") onchange="filterCars()">
                            <label for="filter_coupe">Coupe</label>
                        </div>
                    </div>
                </div>

                <!-- Koltuk Sayısı Filtresi -->
                <div class="item_filter_group">
                    <h4>Koltuk Sayısı</h4>
                    <div class="de_form">
                        <div class="de_checkbox">
                            <input id="seat_all" name="filter_seat" type="radio" value="0" @(string.IsNullOrEmpty(seatsFilter) ? "checked" : "") onchange="filterCars()">
                            <label for="seat_all">Tüm Araçlar</label>
                        </div>
                        <div class="de_checkbox">
                            <input id="seat_2" name="filter_seat" type="radio" value="2" @(seatsFilter == "2" ? "checked" : "") onchange="filterCars()">
                            <label for="seat_2">2 koltuk</label>
                        </div>
                        <div class="de_checkbox">
                            <input id="seat_5" name="filter_seat" type="radio" value="5" @(seatsFilter == "5" ? "checked" : "") onchange="filterCars()">
                            <label for="seat_5">5 koltuk</label>
                        </div>
                        <div class="de_checkbox">
                            <input id="seat_7" name="filter_seat" type="radio" value="7" @(seatsFilter == "7" ? "checked" : "") onchange="filterCars()">
                            <label for="seat_7">7+ koltuk</label>
                        </div>
                    </div>
                </div>

                <!-- Yakıt Tipi Filtresi -->
                <div class="item_filter_group">
                    <h4>Yakıt Tipi</h4>
                    <div class="de_form">
                        <div class="de_checkbox">
                            <input id="fuel_all" name="filter_fuel" type="radio" value="" @(string.IsNullOrEmpty(fuelFilter) ? "checked" : "") onchange="filterCars()">
                            <label for="fuel_all">Tüm Araçlar</label>
                        </div>
                        <div class="de_checkbox">
                            <input id="fuel_benzin" name="filter_fuel" type="radio" value="Benzin" @(fuelFilter == "Benzin" ? "checked" : "") onchange="filterCars()">
                            <label for="fuel_benzin">Benzin</label>
                        </div>
                        <div class="de_checkbox">
                            <input id="fuel_dizel" name="filter_fuel" type="radio" value="Dizel" @(fuelFilter == "Dizel" ? "checked" : "") onchange="filterCars()">
                            <label for="fuel_dizel">Dizel</label>
                        </div>
                        <div class="de_checkbox">
                            <input id="fuel_elektrik" name="filter_fuel" type="radio" value="Elektrik" @(fuelFilter == "Elektrik" ? "checked" : "") onchange="filterCars()">
                            <label for="fuel_elektrik">Elektrik</label>
                        </div>
                        <div class="de_checkbox">
                            <input id="fuel_hibrit" name="filter_fuel" type="radio" value="Hibrit" @(fuelFilter == "Hibrit" ? "checked" : "") onchange="filterCars()">
                            <label for="fuel_hibrit">Hibrit</label>
                        </div>
                    </div>
                </div>

                <!-- Fiyat Aralığı Filtresi -->
                <div class="item_filter_group">
                    <h4>Günlük Fiyat (₺)</h4>
                    <div class="price-input">
                        <div class="field">
                            <span>Min</span>
                            <input type="number" class="input-min" id="minPrice" value="@(string.IsNullOrEmpty(minPriceFilter) ? "0" : minPriceFilter)" onchange="filterCars()">
                        </div>
                        <div class="field">
                            <span>Max</span>
                            <input type="number" class="input-max" id="maxPrice" value="@(string.IsNullOrEmpty(maxPriceFilter) ? "5000" : maxPriceFilter)" onchange="filterCars()">
                        </div>
                    </div>
                </div>

                <!-- Şube Filtresi -->
                <div class="item_filter_group">
                    <h4>Şube</h4>
                    <select id="filter_branch_select" name="filter_branch" class="form-control" onchange="filterCars()">
                        <option value="">Tüm Şubeler</option>
                        @{
                            var branches = ViewBag.Branches as List<Branch> ?? new List<Branch>();
                            foreach (var branch in branches)
                            {
                                bool isSelected = (branchFilter == branch.BranchId.ToString());

                                <option value="@branch.BranchId" selected="@(isSelected ? "selected" : null)">
                                    @branch.BranchName - @branch.City
                                </option>
                            }
                        }
                    </select>
                </div>

                <!-- Arama -->
                <div class="item_filter_group">
                    <h4>Arama</h4>
                    <input type="text" id="searchInput" placeholder="Marka, model ara..." class="form-control" value="@searchFilter" onkeyup="filterCars()">
                </div>
            </div>

            <!-- Araçlar Listesi -->
            <div class="col-lg-9">
                <div id="filterResultContainer" style="margin-bottom: 20px; text-align: center;"></div>
                <div class="row" id="carsList">
                    @if (Model != null && Model.Count > 0)
                    {
                        @foreach (var car in Model)
                        {
                            <div class="col-xl-4 col-lg-6 car-item"
                                 data-brand="@car.Brand?.BrandName?.ToLower()"
                                 data-model="@car.CarModel?.ModelName?.ToLower()"
                                 data-category="@car.Category?.CategoryName?.ToLower()"
                                 data-fuel="@car.FuelType"
                                 data-seats="@car.SeatCount"
                                 data-price="@car.DailyPrice"
                                 data-branch="@car.BranchId">
                                <div class="de-item mb30">
                                    <div class="d-img" style="width: 100%; height: 250px; overflow: hidden; background: #f0f0f0; display: flex; align-items: center; justify-content: center;">
                                        <img src="@car.CoverImageUrl"
                                             loading="lazy"
                                             class="img-fluid"
                                             alt="@car.Brand?.BrandName @car.CarModel?.ModelName"
                                             style="width: 100%; height: 100%; object-fit: cover; object-position: center;"
                                             onerror="this.src='data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%22400%22 height=%22250%22%3E%3Crect fill=%22%23333%22 width=%22400%22 height=%22250%22/%3E%3Ctext x=%2250%25%22 y=%2250%25%22 font-size=%2218%22 fill=%22%23999%22 text-anchor=%22middle%22 dy=%22.3em%22%3EFoto Yok%3C/text%3E%3C/svg%3E'">
                                    </div>
                                    <div class="d-info">
                                        <div class="d-text">
                                            <h4>@car.Brand?.BrandName @car.CarModel?.ModelName</h4>
                                            <div class="d-item_like">
                                                <i class="fa fa-heart"></i><span>0</span>
                                            </div>
                                            <div class="d-atr-group">
                                                <span class="d-atr"><i class="fa fa-map-marker"></i> @(car.Branch?.BranchName ?? "Şube " + car.BranchId)</span>
                                                <span class="d-atr"><i class="fa fa-users"></i> @car.SeatCount</span>
                                                <span class="d-atr"><i class="fa fa-suitcase"></i> @car.LuggageCount</span>
                                                <span class="d-atr"><i class="fa fa-tachometer"></i> @car.Kilometer km</span>
                                                <span class="d-atr"><i class="fa fa-cube"></i> @car.Category?.CategoryName</span>
                                            </div>
                                            <div class="d-price">
                                                Günlük ücret: <span>₺@car.DailyPrice.ToString("N2")</span>
                                                <a class="btn-main" href="/Car/CarDetail/@car.CarId">Detaylar</a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="col-12">
                            <div class="alert alert-info text-center">
                                <h5>Müsait araç bulunamadı.</h5>
                                <p>Lütfen daha sonra tekrar deneyiniz.</p>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        @{
            // Mevcut filtreleri al (page dışındakileri)
            var queryParams = QueryHelpers.ParseQuery(Context.Request.QueryString.Value);
            var filterParams = new Dictionary<string, string>();

            foreach (var param in queryParams)
            {
                if (param.Key.ToLower() != "page")
                {
                    filterParams.Add(param.Key, param.Value);
                }
            }

            // URL oluşturucu yardımcı fonksiyon
            string GetPageUrl(int pageNumber)
            {
                var queryString = new Dictionary<string, string>(filterParams);
                queryString["page"] = pageNumber.ToString();

                var query = QueryString.Create(queryString);
                return "/Car/CarList" + query.Value;
            }
        }

        @if (ViewBag.TotalPages > 1)
        {
            <div class="row mt-5">
                <div class="col-12">
                    <nav aria-label="Page navigation" style="display: flex; justify-content: center; align-items: center; gap: 10px; flex-wrap: wrap;">

                        @if (ViewBag.CurrentPage > 1)
                        {
                            <a href="@GetPageUrl(1)" class="btn-pagination">◀◀ İlk</a>
                            <a href="@GetPageUrl(ViewBag.CurrentPage - 1)" class="btn-pagination">◀ Önceki</a>
                        }
                        else
                        {
                            <span class="btn-pagination-disabled">◀◀ İlk</span>
                            <span class="btn-pagination-disabled">◀ Önceki</span>
                        }

                        <div style="display: flex; gap: 5px;">
                            @{
                                int startPage = Math.Max(1, ViewBag.CurrentPage - 2);
                                int endPage = Math.Min(ViewBag.TotalPages, ViewBag.CurrentPage + 2);
                            }
                            @for (int i = startPage; i <= endPage; i++)
                            {
                                <a href="@GetPageUrl(i)" class="btn-pagination @(i == ViewBag.CurrentPage ? "active" : "")">@i</a>
                            }
                        </div>

                        @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                        {
                            <a href="@GetPageUrl(ViewBag.CurrentPage + 1)" class="btn-pagination">Sonraki ▶</a>
                            <a href="@GetPageUrl(ViewBag.TotalPages)" class="btn-pagination">Son ▶▶</a>
                        }
                        else
                        {
                            <span class="btn-pagination-disabled">Sonraki ▶</span>
                            <span class="btn-pagination-disabled">Son ▶▶</span>
                        }
                    </nav>
                </div>
            </div>
        }

    </div>
</section>

<style>
    /* Checkbox görünümü iyileştirme */
    .de_checkbox {
        margin-bottom: 10px !important;
    }

        .de_checkbox input[type="radio"],
        .de_checkbox input[type="checkbox"] {
            cursor: pointer;
            width: 18px !important;
            height: 18px !important;
            accent-color: #cc0c0c !important;
            margin-right: 8px !important;
        }

        .de_checkbox label {
            cursor: pointer !important;
            user-select: none;
            transition: all 0.2s ease !important;
        }

        .de_checkbox input:checked + label {
            color: #cc0c0c !important;
            font-weight: bold !important;
        }

    /* Araç kartı boyut standardizasyonu */
    .car-item {
        display: flex;
        margin-bottom: 20px !important;
    }

    .de-item {
        display: flex !important;
        flex-direction: column !important;
        height: 100% !important;
        width: 100% !important;
        background: #1a1a1a !important;
        border-radius: 8px !important;
        overflow: hidden !important;
        box-shadow: 0 2px 8px rgba(0,0,0,0.3) !important;
        transition: transform 0.3s ease !important;
    }

        .de-item:hover {
            transform: translateY(-5px) !important;
        }

        .de-item .d-img {
            width: 100% !important;
            height: 250px !important;
            min-height: 250px !important;
            max-height: 250px !important;
            overflow: hidden !important;
            background: #2a2a2a !important;
            display: flex !important;
            align-items: center !important;
            justify-content: center !important;
            flex-shrink: 0 !important;
            border-radius: 8px 8px 0 0 !important;
        }

            .de-item .d-img img {
                width: 100% !important;
                height: 100% !important;
                object-fit: cover !important;
                object-position: center !important;
            }

        .de-item .d-info {
            flex: 1 !important;
            display: flex !important;
            flex-direction: column !important;
            padding: 15px !important;
        }

        .de-item .d-text {
            flex: 1 !important;
            display: flex !important;
            flex-direction: column !important;
        }

    /* Filtreleme sonuç stili */
    #filterResult {
        padding: 12px 20px !important;
        margin-bottom: 20px !important;
        border-radius: 6px !important;
        font-weight: bold !important;
        text-align: center !important;
        animation: slideDown 0.3s ease-out !important;
    }

    @@keyframes slideDown {
        from {
            opacity: 0;
            transform: translateY(-10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Row gap */
    .row.g-4 {
        gap: 20px !important;
        row-gap: 20px !important;
    }

    .col-xl-4, .col-lg-6 {
        padding-right: 10px !important;
        padding-left: 10px !important;
    }

    .btn-pagination {
        padding: 8px 15px;
        border: 2px solid #cc0c0c;
        color: #cc0c0c;
        text-decoration: none;
        border-radius: 4px;
        font-weight: bold;
        transition: 0.3s;
    }

    .btn-pagination:hover {
        background: #cc0c0c;
        color: white;
    }

    .btn-pagination.active {
        background: #cc0c0c;
        color: white;
    }

    .btn-pagination-disabled {
        padding: 8px 15px;
        border: 2px solid #ccc;
        color: #ccc;
        border-radius: 4px;
        font-weight: bold;
        cursor: not-allowed;
    }
</style>


@section Scripts {
    <script>
            function filterCars() {
        // Radyo butonlarından seçili olan değeri al
                const category = document.querySelector('input[name="filter_category"]:checked')?.value || '0';
                const seats = document.querySelector('input[name="filter_seat"]:checked')?.value || '0';
                const fuel = document.querySelector('input[name="filter_fuel"]:checked')?.value || '';
                const branch = document.getElementById('filter_branch_select').value;
                const minPrice = document.getElementById('minPrice').value;
                const maxPrice = document.getElementById('maxPrice').value;
                const search = document.getElementById('searchInput').value;

                // URL parametrelerini oluştur
                let url = `/Car/CarList?page=1`;
                if (category !== '0') url += `&category=${encodeURIComponent(category)}`;
                if (seats !== '0') url += `&seats=${seats}`;
                if (fuel) url += `&fuel=${encodeURIComponent(fuel)}`;
                if (branch) url += `&branch=${branch}`;
                if (minPrice && minPrice !== '0') url += `&minPrice=${minPrice}`;
                if (maxPrice && maxPrice !== '5000') url += `&maxPrice=${maxPrice}`;
                if (search) url += `&search=${encodeURIComponent(search)}`;

                // Sayfayı yeni URL ile yenile
                window.location.href = url;
            }

        // Checkbox stillerini güncelle
        function updateCheckboxes() {
            document.querySelectorAll('input[type="radio"]').forEach(radio => {
                const label = document.querySelector(`label[for="${radio.id}"]`);
                if (label) {
                    label.style.color = radio.checked ? '#cc0c0c' : 'inherit';
                    label.style.fontWeight = radio.checked ? 'bold' : 'normal';
                }
            });
        }

        document.addEventListener('DOMContentLoaded', function () {
            updateCheckboxes();
        });
    </script>
}