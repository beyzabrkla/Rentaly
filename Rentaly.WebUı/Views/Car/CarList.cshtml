@using Rentaly.EntityLayer.Entities
@model List<Car>
@{
    ViewData["Title"] = "CarList";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section id="subheader" class="jarallax text-light">
    <img src="/RentalyHTML/images/background/2.jpg" class="jarallax-img" alt="">
    <div class="center-y relative text-center">
        <div class="container">
            <div class="row">
                <div class="col-md-12 text-center">
                    <h1>Araçlarımız</h1>
                </div>
                <div class="clearfix"></div>
            </div>
        </div>
    </div>
</section>

<section id="section-cars">
    <div class="container">
        <div class="row">
            <!-- Sol Filtreleme Paneli -->
            <div class="col-lg-3">
                <!-- Kategori Filtresi -->
                <div class="item_filter_group">
                    <h4>Kategori</h4>
                    <div class="de_form">
                        <div class="de_checkbox">
                            <input id="filter_all" name="filter_category" type="radio" value="0" checked onchange="filterCars()">
                            <label for="filter_all">Tüm Araçlar</label>
                        </div>
                        <div class="de_checkbox">
                            <input id="filter_sedan" name="filter_category" type="radio" value="sedan" onchange="filterCars()">
                            <label for="filter_sedan">Sedan</label>
                        </div>
                        <div class="de_checkbox">
                            <input id="filter_suv" name="filter_category" type="radio" value="suv" onchange="filterCars()">
                            <label for="filter_suv">SUV</label>
                        </div>
                        <div class="de_checkbox">
                            <input id="filter_hatchback" name="filter_category" type="radio" value="hatchback" onchange="filterCars()">
                            <label for="filter_hatchback">Hatchback</label>
                        </div>
                        <div class="de_checkbox">
                            <input id="filter_coupe" name="filter_category" type="radio" value="coupe" onchange="filterCars()">
                            <label for="filter_coupe">Coupe</label>
                        </div>
                    </div>
                </div>

                <!-- Koltuk Sayısı Filtresi -->
                <div class="item_filter_group">
                    <h4>Koltuk Sayısı</h4>
                    <div class="de_form">
                        <div class="de_checkbox">
                            <input id="seat_all" name="filter_seat" type="radio" value="0" checked onchange="filterCars()">
                            <label for="seat_all">Tüm Araçlar</label>
                        </div>
                        <div class="de_checkbox">
                            <input id="seat_2" name="filter_seat" type="radio" value="2" onchange="filterCars()">
                            <label for="seat_2">2 koltuk</label>
                        </div>
                        <div class="de_checkbox">
                            <input id="seat_5" name="filter_seat" type="radio" value="5" onchange="filterCars()">
                            <label for="seat_5">5 koltuk</label>
                        </div>
                        <div class="de_checkbox">
                            <input id="seat_7" name="filter_seat" type="radio" value="7" onchange="filterCars()">
                            <label for="seat_7">7+ koltuk</label>
                        </div>
                    </div>
                </div>

                <!-- Yakıt Tipi Filtresi -->
                <div class="item_filter_group">
                    <h4>Yakıt Tipi</h4>
                    <div class="de_form">
                        <div class="de_checkbox">
                            <input id="fuel_all" name="filter_fuel" type="radio" value="" checked onchange="filterCars()">
                            <label for="fuel_all">Tüm Araçlar</label>
                        </div>
                        <div class="de_checkbox">
                            <input id="fuel_benzin" name="filter_fuel" type="radio" value="Benzin" onchange="filterCars()">
                            <label for="fuel_benzin">Benzin</label>
                        </div>
                        <div class="de_checkbox">
                            <input id="fuel_dizel" name="filter_fuel" type="radio" value="Dizel" onchange="filterCars()">
                            <label for="fuel_dizel">Dizel</label>
                        </div>
                        <div class="de_checkbox">
                            <input id="fuel_elektrik" name="filter_fuel" type="radio" value="Elektrik" onchange="filterCars()">
                            <label for="fuel_elektrik">Elektrik</label>
                        </div>
                        <div class="de_checkbox">
                            <input id="fuel_hibrit" name="filter_fuel" type="radio" value="Hibrit" onchange="filterCars()">
                            <label for="fuel_hibrit">Hibrit</label>
                        </div>
                    </div>
                </div>

                <!-- Fiyat Aralığı Filtresi -->
                <div class="item_filter_group">
                    <h4>Günlük Fiyat (₺)</h4>
                    <div class="price-input">
                        <div class="field">
                            <span>Min</span>
                            <input type="number" class="input-min" id="minPrice" value="0" onchange="filterByPrice()">
                        </div>
                        <div class="field">
                            <span>Max</span>
                            <input type="number" class="input-max" id="maxPrice" value="5000" onchange="filterByPrice()">
                        </div>
                    </div>
                </div>

                <!-- Arama -->
                <div class="item_filter_group">
                    <h4>Arama</h4>
                    <input type="text" id="searchInput" placeholder="Marka, model ara..." class="form-control" onkeyup="filterCars()">
                </div>
            </div>

            <!-- Araçlar Listesi -->
            <div class="col-lg-9">
                <div class="row" id="carsList">
                    @if (Model != null && Model.Count > 0)
                    {
                        @foreach (var car in Model)
                        {
                            <div class="col-xl-4 col-lg-6 car-item"
                                 data-brand="@car.Brand?.BrandName?.ToLower()"
                                 data-model="@car.CarModel?.ModelName?.ToLower()"
                                 data-category="@car.Category?.CategoryName?.ToLower()"
                                 data-fuel="@car.FuelType"
                                 data-seats="@car.SeatCount"
                                 data-price="@car.DailyPrice">
                                <div class="de-item mb30">
                                    <div class="d-img">
                                        <img src="@car.ImageUrl"
                                             class="img-fluid"
                                             alt="@car.Brand?.BrandName @car.CarModel?.ModelName"
                                             onerror="this.src='data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%22400%22 height=%22300%22%3E%3Crect fill=%22%23333%22 width=%22400%22 height=%22300%22/%3E%3Ctext x=%2250%25%22 y=%2250%25%22 font-size=%2220%22 fill=%22%23666%22 text-anchor=%22middle%22 dy=%22.3em%22%3EAraç Görseli Yok%3C/text%3E%3C/svg%3E'">
                                    </div>
                                    <div class="d-info">
                                        <div class="d-text">
                                            <h4>@car.Brand?.BrandName @car.CarModel?.ModelName</h4>
                                            <div class="d-item_like">
                                                <i class="fa fa-heart"></i><span>0</span>
                                            </div>
                                            <div class="d-atr-group">
                                                <span class="d-atr"><i class="fa fa-users"></i> @car.SeatCount</span>
                                                <span class="d-atr"><i class="fa fa-suitcase"></i> @car.LuggageCount</span>
                                                <span class="d-atr"><i class="fa fa-tachometer"></i> @car.Kilometer km</span>
                                                <span class="d-atr"><i class="fa fa-cube"></i> @car.Category?.CategoryName</span>
                                            </div>
                                            <div class="d-price">
                                                Günlük ücret: <span>₺@car.DailyPrice.ToString("N2")</span>
                                                <a class="btn-main" href="/Car/CarDetail/@car.CarId">Detaylar</a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="col-12">
                            <div class="alert alert-info text-center">
                                <h5>Müsait araç bulunamadı.</h5>
                                <p>Lütfen daha sonra tekrar deneyiniz.</p>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        // Araçları filtrele
        function filterCars() {
            try {
                const category = document.querySelector('input[name="filter_category"]:checked')?.value || '';
                const seats = document.querySelector('input[name="filter_seat"]:checked')?.value || '0';
                const fuel = document.querySelector('input[name="filter_fuel"]:checked')?.value || '';
                const searchTerm = document.getElementById('searchInput')?.value.toLowerCase() || '';

                const items = document.querySelectorAll('.car-item');

                items.forEach(item => {
                    let show = true;

                    // Kategori filtresi
                    if (category && category !== '0') {
                        const itemCategory = (item.getAttribute('data-category') || '').toLowerCase();
                        if (!itemCategory.includes(category.toLowerCase())) {
                            show = false;
                        }
                    }

                    // Koltuk filtresi
                    if (seats && seats !== '0') {
                        const itemSeats = parseInt(item.getAttribute('data-seats')) || 0;
                        if (itemSeats !== parseInt(seats)) {
                            show = false;
                        }
                    }

                    // Yakıt filtresi
                    if (fuel && fuel !== '') {
                        const itemFuel = item.getAttribute('data-fuel') || '';
                        if (itemFuel !== fuel) {
                            show = false;
                        }
                    }

                    // Arama terimi
                    if (searchTerm) {
                        const brand = (item.getAttribute('data-brand') || '').toLowerCase();
                        const model = (item.getAttribute('data-model') || '').toLowerCase();
                        if (!brand.includes(searchTerm) && !model.includes(searchTerm)) {
                            show = false;
                        }
                    }

                    item.style.display = show ? 'block' : 'none';
                });
            } catch (e) {
                console.error('Filter hatası:', e);
            }
        }

        // Fiyat aralığına göre filtrele
        function filterByPrice() {
            try {
                const minPrice = parseFloat(document.getElementById('minPrice')?.value) || 0;
                const maxPrice = parseFloat(document.getElementById('maxPrice')?.value) || 999999;

                const items = document.querySelectorAll('.car-item');

                items.forEach(item => {
                    const price = parseFloat(item.getAttribute('data-price')) || 0;
                    if (price >= minPrice && price <= maxPrice) {
                        item.style.display = 'block';
                    } else {
                        item.style.display = 'none';
                    }
                });
            } catch (e) {
                console.error('Fiyat filtresi hatası:', e);
            }
        }

        // Sayfa yüklendiğinde
        document.addEventListener('DOMContentLoaded', function () {
            filterCars();
        });
    </script>
}
