@using Microsoft.AspNetCore.WebUtilities
@using Rentaly.EntityLayer.Entities
@using System.Globalization
@model List<ResultCarDTO>
@{
    ViewData["Title"] = "Araç Listesi";
    Layout = "~/Views/Shared/_Layout.cshtml";

    string categoryFilter = Context.Request.Query["category"];
    string seatsFilter = Context.Request.Query["seats"];
    string fuelFilter = Context.Request.Query["fuel"];
    string branchFilter = Context.Request.Query["branch"];
    string searchFilter = Context.Request.Query["search"];
    string minPriceFilter = Context.Request.Query["minPrice"];
    string maxPriceFilter = Context.Request.Query["maxPrice"];
    string pickupDate = Context.Request.Query["pickupDate"];
    string dropOffDate = Context.Request.Query["dropOffDate"];
}

<section id="subheader" class="jarallax text-light">
    <img src="/RentalyHTML/images/background/2.jpg" class="jarallax-img" alt="">
    <div class="center-y relative text-center">
        <div class="container">
            <div class="row">
                <div class="col-md-12 text-center">
                    <h1>Araçlarımız</h1>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="section-cars">
    <div class="container">
        <div class="row">
            <div class="col-lg-3">
                <div class="item_filter_group">
                    <h4>Kategori</h4>
                    <div class="de_form">
                        <div class="de_checkbox">
                            <input id="filter_all" name="filter_category" type="radio" value="0"
                            @(string.IsNullOrEmpty(categoryFilter) || categoryFilter == "0" ? "checked" : "")
                                   onchange="filterCars()">
                            <label for="filter_all">Tüm Araçlar</label>
                        </div>
                        @foreach (var cat in ViewBag.Categories as List<Category> ?? new List<Category>())
                        {
                            var catVal = cat.CategoryName;
                            var catId = "filter_" + cat.CategoryId;
                            <div class="de_checkbox">
                                <input id="@catId" name="filter_category" type="radio" value="@catVal"
                                @(categoryFilter == catVal ? "checked" : "")
                                       onchange="filterCars()">
                                <label for="@catId">@cat.CategoryName</label>
                            </div>
                        }
                    </div>
                </div>

                <div class="item_filter_group">
                    <h4>Koltuk Sayısı</h4>
                    <div class="de_form">
                        <div class="de_checkbox">
                            <input id="seat_all" name="filter_seat" type="radio" value="0" @(string.IsNullOrEmpty(seatsFilter) || seatsFilter == "0" ? "checked" : "") onchange="filterCars()">
                            <label for="seat_all">Tümü</label>
                        </div>
                        <div class="de_checkbox">
                            <input id="seat_2" name="filter_seat" type="radio" value="2" @(seatsFilter == "2" ? "checked" : "") onchange="filterCars()">
                            <label for="seat_2">2 Koltuk</label>
                        </div>
                        <div class="de_checkbox">
                            <input id="seat_5" name="filter_seat" type="radio" value="5" @(seatsFilter == "5" ? "checked" : "") onchange="filterCars()">
                            <label for="seat_5">5 Koltuk</label>
                        </div>
                        <div class="de_checkbox">
                            <input id="seat_7" name="filter_seat" type="radio" value="7" @(seatsFilter == "7" ? "checked" : "") onchange="filterCars()">
                            <label for="seat_7">7+ Koltuk</label>
                        </div>
                    </div>
                </div>

                <div class="item_filter_group">
                    <h4>Yakıt Tipi</h4>
                    <div class="de_form">
                        <div class="de_checkbox">
                            <input id="fuel_all" name="filter_fuel" type="radio" value="" @(string.IsNullOrEmpty(fuelFilter) ? "checked" : "") onchange="filterCars()">
                            <label for="fuel_all">Tümü</label>
                        </div>
                        @foreach (var f in new[] { "Benzin", "Dizel", "Elektrik", "Hibrit" })
                        {
                            <div class="de_checkbox">
                                <input id="fuel_@f" name="filter_fuel" type="radio" value="@f" @(fuelFilter == f ? "checked" : "") onchange="filterCars()">
                                <label for="fuel_@f">@f</label>
                            </div>
                        }
                    </div>
                </div>

                <div class="item_filter_group">
                    <h4>Günlük Fiyat (₺)</h4>
                    <div class="price-input">
                        <input type="number" id="minPrice" class="form-control" placeholder="Min" value="@minPriceFilter" onchange="filterCars()">
                        <input type="number" id="maxPrice" class="form-control" placeholder="Max" value="@maxPriceFilter" onchange="filterCars()">
                    </div>
                </div>

                <div class="item_filter_group">
                    <h4>Şube</h4>
                    <select id="filter_branch_select" class="form-control" onchange="filterCars()">
                        <option value="0">Tüm Şubeler</option>
                        @foreach (var branch in ViewBag.Branches as List<Branch> ?? new List<Branch>())
                        {
                            // Koşulu dışarıda bir değişkene alıyoruz
                            bool isSelected = ViewBag.SelectedBranch != null && (int)ViewBag.SelectedBranch == branch.BranchId;

                            <option value="@branch.BranchId" selected="@(isSelected ? "selected" : null)">
                                @branch.BranchName
                            </option>
                        }
                    </select>
                </div>
                <div class="item_filter_group">
                    <h4>Marka/Model Ara</h4>
                    <input type="text" id="searchInput" class="form-control" placeholder="Ara..." value="@searchFilter" onkeyup="filterCars()">
                </div>
            </div>

            <div class="col-lg-9">
                <div class="row">
                    @if (Model.Any())
                    {
                        @foreach (var car in Model)
                        {
                            <div class="col-xl-4 col-lg-6 mb-4">
                                <div class="de-item mb30">
                                    <div class="d-img">
                                        <img src="@car.CoverImageUrl" class="img-fluid" alt="">
                                    </div>
                                    <div class="d-info">
                                        <div class="d-text">
                                            <h4>@car.BrandName @car.CarModelName</h4>
                                            <div class="d-atr-group">
                                                <span class="d-atr"><i class="fa fa-users"></i> @car.SeatCount</span>
                                                <span class="d-atr"><i class="fa fa-tachometer"></i> @car.Kilometer km</span>
                                                <span class="d-atr"><i class="fa fa-map-marker"></i> @car.BranchName</span>
                                            </div>
                                            <div class="d-price">
                                                Günlük: <span>₺@car.DailyPrice.ToString("N0", new CultureInfo("tr-TR"))</span>
                                                <a class="btn-main" href="/Car/CarDetail/@car.CarId">Kirala</a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="col-12 text-center">
                            <div class="alert alert-warning">Aradığınız kriterlere uygun araç bulunamadı.</div>
                        </div>
                    }
                </div>

                @if (ViewBag.TotalPages > 1)
                {
                    <div class="pagination-wrapper mt-4 text-center">
                        @{
                            var queryParams = QueryHelpers.ParseQuery(Context.Request.QueryString.Value);
                            var filterParams = new Dictionary<string, string>();
                            foreach (var p in queryParams) if (p.Key.ToLower() != "page") filterParams[p.Key] = p.Value;

                            string GetUrl(int p)
                            {
                                var dict = new Dictionary<string, string>(filterParams);
                                dict["page"] = p.ToString();
                                return "/Car/CarList" + QueryString.Create(dict).Value;
                            }
                        }
                        
                        @for (int i = 1; i <= ViewBag.TotalPages; i++)
                        {
                            <a href="@GetUrl(i)" class="btn-pagination @(i == ViewBag.CurrentPage ? "active" : "")">@i</a>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</section>

<style>
    /* Checkbox görünümü iyileştirme */
    .de_checkbox {
        margin-bottom: 10px !important;
    }

        .de_checkbox input[type="radio"],
        .de_checkbox input[type="checkbox"] {
            cursor: pointer;
            width: 18px !important;
            height: 18px !important;
            accent-color: #cc0c0c !important;
            margin-right: 8px !important;
        }

        .de_checkbox label {
            cursor: pointer !important;
            user-select: none;
            transition: all 0.2s ease !important;
        }

        .de_checkbox input:checked + label {
            color: #cc0c0c !important;
            font-weight: bold !important;
        }

    /* Araç kartı boyut standardizasyonu */
    .car-item {
        display: flex;
        margin-bottom: 20px !important;
    }

    .de-item {
        display: flex !important;
        flex-direction: column !important;
        height: 100% !important;
        width: 100% !important;
        background: #1a1a1a !important;
        border-radius: 8px !important;
        overflow: hidden !important;
        box-shadow: 0 2px 8px rgba(0,0,0,0.3) !important;
        transition: transform 0.3s ease !important;
    }

        .de-item:hover {
            transform: translateY(-5px) !important;
        }

        .de-item .d-img {
            width: 100% !important;
            height: 250px !important;
            min-height: 250px !important;
            max-height: 250px !important;
            overflow: hidden !important;
            background: #2a2a2a !important;
            display: flex !important;
            align-items: center !important;
            justify-content: center !important;
            flex-shrink: 0 !important;
            border-radius: 8px 8px 0 0 !important;
        }

            .de-item .d-img img {
                width: 100% !important;
                height: 100% !important;
                object-fit: cover !important;
                object-position: center !important;
            }

        .de-item .d-info {
            flex: 1 !important;
            display: flex !important;
            flex-direction: column !important;
            padding: 15px !important;
        }

        .de-item .d-text {
            flex: 1 !important;
            display: flex !important;
            flex-direction: column !important;
        }

    /* Filtreleme sonuç stili */
    #filterResult {
        padding: 12px 20px !important;
        margin-bottom: 20px !important;
        border-radius: 6px !important;
        font-weight: bold !important;
        text-align: center !important;
        animation: slideDown 0.3s ease-out !important;
    }

    @@keyframes slideDown {
        from {
            opacity: 0;
            transform: translateY(-10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Row gap */
    .row.g-4 {
        gap: 20px !important;
        row-gap: 20px !important;
    }

    .col-xl-4, .col-lg-6 {
        padding-right: 10px !important;
        padding-left: 10px !important;
    }

    .btn-pagination {
        padding: 8px 15px;
        border: 2px solid #cc0c0c;
        color: #cc0c0c;
        text-decoration: none;
        border-radius: 4px;
        font-weight: bold;
        transition: 0.3s;
    }

    .btn-pagination:hover {
        background: #cc0c0c;
        color: white;
    }

    .btn-pagination.active {
        background: #cc0c0c;
        color: white;
    }

    .btn-pagination-disabled {
        padding: 8px 15px;
        border: 2px solid #ccc;
        color: #ccc;
        border-radius: 4px;
        font-weight: bold;
        cursor: not-allowed;
    }
</style>


@section Scripts {
    <script>
        function filterCars() {
            const category = document.querySelector('input[name="filter_category"]:checked')?.value || '0';
            const seats = document.querySelector('input[name="filter_seat"]:checked')?.value || '0';
            const fuel = document.querySelector('input[name="filter_fuel"]:checked')?.value || '';
            const branch = document.getElementById('filter_branch_select').value;
            const minPrice = document.getElementById('minPrice').value;
            const maxPrice = document.getElementById('maxPrice').value;
            const search = document.getElementById('searchInput').value;

            // Mevcut tarihleri koru
            const urlParams = new URLSearchParams(window.location.search);
            const pDate = urlParams.get('pickupDate');
            const dDate = urlParams.get('dropOffDate');

            let url = `/Car/CarList?page=1`;
            if (category !== '0') url += `&category=${encodeURIComponent(category)}`;
            if (seats !== '0') url += `&seats=${seats}`;
            if (fuel) url += `&fuel=${encodeURIComponent(fuel)}`;
            if (branch !== '0') url += `&branch=${branch}`;
            if (minPrice) url += `&minPrice=${minPrice}`;
            if (maxPrice) url += `&maxPrice=${maxPrice}`;
            if (search) url += `&search=${encodeURIComponent(search)}`;
            if (pDate) url += `&pickupDate=${pDate}`;
            if (dDate) url += `&dropOffDate=${dDate}`;

            window.location.href = url;
        }
    </script>
}