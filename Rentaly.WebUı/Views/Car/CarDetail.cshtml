@using Rentaly.EntityLayer.Entities
@model Car
@{
    ViewData["Title"] = $"{Model?.Brand?.BrandName} {Model?.CarModel?.ModelName} - Detaylar";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section id="subheader" class="jarallax text-light">
    <img src="/RentalyHTML/images/background/2.jpg" class="jarallax-img" alt="">
    <div class="center-y relative text-center">
        <div class="container">
            <div class="row">
                <div class="col-md-12 text-center">
                    <h1>@Model?.Brand?.BrandName @Model?.CarModel?.ModelName - @Model?.Year</h1>
                </div>
                <div class="clearfix"></div>
            </div>
        </div>
    </div>
</section>

<section id="section-car-details">
    <div class="container">
        <div class="row g-5">
            <!-- Araç Görseli -->
            <div class="col-lg-6">
                <div class="car-image-container">
                    <img src="@Model?.CoverImageUrl"
                         class="img-fluid rounded"
                         alt="@Model?.Brand?.BrandName @Model?.CarModel?.ModelName"
                         onerror="this.src='data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%22500%22 height=%22400%22%3E%3Crect fill=%22%23333%22 width=%22500%22 height=%22400%22/%3E%3Ctext x=%2250%25%22 y=%2250%25%22 font-size=%2224%22 fill=%22%23666%22 text-anchor=%22middle%22 dy=%22.3em%22%3EAraç Görseli Yok%3C/text%3E%3C/svg%3E'">
                </div>
            </div>

            <!-- Araç Bilgileri -->
            <div class="col-lg-3">
                <h3>@Model?.Brand?.BrandName @Model?.CarModel?.ModelName</h3>
                <p>@Model?.Category?.CategoryName kategorisinde, @Model?.Year yılında üretilmiş güvenilir ve konforlu bir araçtır.</p>

                <div class="spacer-10"></div>

                <h4>Teknik Özellikler</h4>
                <div class="de-spec">
                    <div class="d-row">
                        <span class="d-title">Kategori</span>
                        <span class="d-value">@Model?.Category?.CategoryName</span>
                    </div>
                    <div class="d-row">
                        <span class="d-title">Koltuk Sayısı</span>
                        <span class="d-value">@Model?.SeatCount koltuk</span>
                    </div>
                    <div class="d-row">
                        <span class="d-title">Bagaj Kapasitesi</span>
                        <span class="d-value">@Model?.LuggageCount</span>
                    </div>
                    <div class="d-row">
                        <span class="d-title">Yakıt Tipi</span>
                        <span class="d-value">@Model?.FuelType</span>
                    </div>
                    <div class="d-row">
                        <span class="d-title">Şanzıman</span>
                        <span class="d-value">@Model?.Transmission</span>
                    </div>
                    <div class="d-row">
                        <span class="d-title">Üretim Yılı</span>
                        <span class="d-value">@Model?.Year</span>
                    </div>
                    <div class="d-row">
                        <span class="d-title">Kilometre</span>
                        <span class="d-value">@Model?.Kilometer km</span>
                    </div>
                    <div class="d-row">
                        <span class="d-title">Plaka</span>
                        <span class="d-value">@Model?.PlateNumber</span>
                    </div>
                    <div class="d-row">
                        <span class="d-title">Şasi Numarası</span>
                        <span class="d-value">@Model?.VIN</span>
                    </div>
                    <div class="d-row">
                        <span class="d-title">Mevcut Şube</span>
                        <span class="d-value">@Model?.Branch?.BranchName</span>
                    </div>
                </div>

                <div class="spacer-single"></div>

                <h4>Durum</h4>
                <ul class="ul-style-2">
                    @if (Model?.IsAvailable == true)
                    {
                        <li><i class="fa fa-check text-success"></i> Müsait</li>
                    }
                    else
                    {
                        <li><i class="fa fa-times text-danger"></i> Kirada</li>
                    }
                    @if (Model?.IsActive == true)
                    {
                        <li><i class="fa fa-check text-success"></i> Aktif</li>
                    }
                </ul>
            </div>

            <!-- Rezervasyon Paneli -->
            <div class="col-lg-3">
                <!-- Fiyat -->
                <div class="de-price text-center">
                    <p>Günlük Ücret</p>
                    <h3>₺@Model?.DailyPrice.ToString("N2")</h3>
                    <p class="text-muted">Depozito: ₺@Model?.DepositAmount.ToString("N2")</p>
                </div>

                <div class="spacer-30"></div>

                <!-- Rezervasyon Formu -->
                @if (Model?.IsAvailable == true)
                {
                    <div class="de-box text-light mb25">
                        <form name="bookingForm" id="booking_form" method="post" action="/Rental/Create">
                            <h4>Bu Aracı Kiralayın</h4>

                            <div class="spacer-20"></div>

                            <!-- Araç ID (Hidden) -->
                            <input type="hidden" name="CarId" value="@Model?.CarId">

                            <!-- Teslim Lokasyonu -->
                            <div class="mb20">
                                <h5>Teslim Yeri</h5>
                                <select name="PickupBranchId" class="form-control" required>
                                    <option value="">-- Şube Seçin --</option>
                                    <option value="@Model?.BranchId" selected>@Model?.Branch?.BranchName (@Model?.Branch?.City)</option>
                                </select>
                            </div>

                            <!-- Dönem Lokasyonu -->
                            <div class="mb20">
                                <h5>Dönem Yeri</h5>
                                <select name="ReturnBranchId" class="form-control" required>
                                    <option value="">-- Şube Seçin --</option>
                                    <option value="@Model?.BranchId" selected>@Model?.Branch?.BranchName (@Model?.Branch?.City)</option>
                                </select>
                            </div>

                            <!-- Teslim Tarihi & Saati -->
                            <div class="mb20">
                                <h5>Teslim Tarihi & Saati</h5>
                                <div class="date-time-field">
                                    <input type="date" name="PickupDate" value="" required class="form-control">
                                    <input type="time" name="PickupTime" value="09:00" class="form-control">
                                </div>
                            </div>

                            <!-- Dönem Tarihi & Saati -->
                            <div class="mb20">
                                <h5>Dönem Tarihi & Saati</h5>
                                <div class="date-time-field">
                                    <input type="date" name="ReturnDate" value="" required class="form-control">
                                    <input type="time" name="ReturnTime" value="10:00" class="form-control">
                                </div>
                            </div>

                            <button type="submit" class="btn-main btn-fullwidth">Şimdi Kirala</button>

                            <div class="clearfix"></div>
                        </form>
                    </div>
                }
                else
                {
                    <div class="alert alert-danger text-center">
                        <h5>Araç Müsait Değildir</h5>
                        <p>Bu araç şu anda kiralanmıştır. Lütfen başka bir araç seçiniz.</p>
                        <a href="/Car/CarList" class="btn-main">Araç Listesine Dön</a>
                    </div>
                }

                <div class="spacer-30"></div>

                <!-- Paylaş -->
                <div class="de-box">
                    <h4>Paylaş</h4>
                    <div class="de-color-icons">
                        <a href="https://twitter.com/intent/tweet?text=Check out this car: @Model?.Brand?.BrandName @Model?.CarModel?.ModelName" target="_blank" title="Twitter">
                            <i class="fa fa-twitter fa-lg"></i>
                        </a>
                        <a href="https://www.facebook.com/sharer/sharer.php" target="_blank" title="Facebook">
                            <i class="fa fa-facebook fa-lg"></i>
                        </a>
                        <a href="https://www.linkedin.com/sharing/share-offsite/" target="_blank" title="LinkedIn">
                            <i class="fa fa-linkedin fa-lg"></i>
                        </a>
                        <a href="mailto:?subject=Check out this car&body=@Model?.Brand?.BrandName @Model?.CarModel?.ModelName" title="Email">
                            <i class="fa fa-envelope fa-lg"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        // Tarih minimum değeri bugün olsun
        document.addEventListener('DOMContentLoaded', function () {
            try {
                const today = new Date().toISOString().split('T')[0];
                const pickupDate = document.querySelector('input[name="PickupDate"]');
                const returnDate = document.querySelector('input[name="ReturnDate"]');

                if (pickupDate) {
                    pickupDate.min = today;
                    pickupDate.value = today;
                }
                if (returnDate) {
                    returnDate.min = today;
                    returnDate.value = today;
                }

                // Dönem tarihi >= Teslim tarihi olsun
                if (pickupDate) {
                    pickupDate.addEventListener('change', function () {
                        if (returnDate) {
                            returnDate.min = this.value;
                            if (returnDate.value < this.value) {
                                returnDate.value = this.value;
                            }
                        }
                    });
                }
            } catch (e) {
                console.error('Tarih ayarlaması hatası:', e);
            }
        });
    </script>
}
