@model RentalIndexViewModel
@{
    ViewData["Title"] = "Rezervasyon";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<style>
    /* Mevcut stillerin aynı kalabilir, sadece eklemeler yapıldı */
    .custom-input[readonly] { background: rgba(255,255,255,0.1) !important; cursor: not-allowed; opacity: 0.8; }
    .field-validation-error { color: #ff4d4d; font-size: 12px; margin-top: 5px; display: block; font-weight: 500; }
    .input-validation-error { border: 1px solid #ff4d4d !important; background: rgba(255,77,77,0.05) !important; }
    .date-time-group { display: flex; gap: 8px; }
    .date-time-group input { flex: 1; }
    .date-time-group select { width: 105px; flex-shrink: 0; }
</style>

<section id="subheader" class="jarallax text-light">
    <img src="/RentalyHTML/images/background/2.jpg" class="jarallax-img" alt="">
    <div class="center-y relative text-center">
        <div class="container">
            <h1>Rezervasyon İşlemleri</h1>
        </div>
    </div>
</section>

<section id="section-rent-form" style="padding: 60px 0;">
    <div class="container">
        <div class="row g-5 align-items-start">

            <div class="col-lg-8">
                <div class="de-box" style="background: rgba(255,255,255,0.02); padding: 30px; border-radius: 12px; border: 1px solid rgba(255,255,255,0.05);">

                    <div id="validationSummary" class="alert alert-danger mb-4" 
                         style="background: rgba(255,77,77,0.1); border: 1px solid #ff4d4d; color: white; @(ViewData.ModelState.IsValid ? "display:none;" : "")">
                        <div asp-validation-summary="ModelOnly"></div>
                    </div>

                    <form method="post" action="/Rental/Index" id="rentalForm">
                        @Html.HiddenFor(x => x.CreateRentalDto.CarId)
                        @Html.HiddenFor(x => x.CreateRentalDto.DailyPrice)
                        @Html.HiddenFor(x => x.CreateRentalDto.DepositAmount) @* Depozito Hidden *@
                        @Html.HiddenFor(x => x.CreateRentalDto.TotalPrice, new { id = "hdnTotalPrice" })
                        
                        <input type="hidden" asp-for="CreateRentalDto.PickupBranchId" />
                        <input type="hidden" asp-for="CreateRentalDto.PickupDate" id="hdnPickupDate" />
                        <input type="hidden" asp-for="CreateRentalDto.ReturnDate" id="hdnReturnDate" />

                        <div class="row">
                            <div class="col-md-12 mb-4">
                                <h5 class="text-white border-bottom pb-2">Kiralama Detayları</h5>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="text-white-50 small">Alış Şubesi</label>
                                <input type="text" class="form-control custom-input" value="@Model.CurrentBranchName" readonly>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="text-white-50 small">Dönüş Şubesi</label>
                                <select asp-for="CreateRentalDto.ReturnBranchId" class="form-control custom-input"
                                        asp-items="@(new SelectList(ViewBag.Branches, "BranchId", "BranchName"))">
                                    <option value="">Şube Seçiniz</option>
                                </select>
                                <span asp-validation-for="CreateRentalDto.ReturnBranchId" class="field-validation-error"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="text-white-50 small">Alış Tarihi</label>
                                <div class="date-time-group">
                                    <input type="text" id="pickUpDateUI" class="form-control custom-input" placeholder="Tarih seçin...">
                                    <select id="pickUpTime" class="form-control custom-input">
                                        @for (int i = 8; i <= 22; i++) { <option value="@i">@i:00</option> }
                                    </select>
                                </div>
                                <span asp-validation-for="CreateRentalDto.PickupDate" class="field-validation-error"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="text-white-50 small">Dönüş Tarihi</label>
                                <div class="date-time-group">
                                    <input type="text" id="dropOffDateUI" class="form-control custom-input" placeholder="Tarih seçin...">
                                    <select id="dropOffTime" class="form-control custom-input">
                                        @for (int i = 8; i <= 22; i++) { <option value="@i" selected="@(i == 10 ? "selected" : null)">@i:00</option> }
                                    </select>
                                </div>
                                <span asp-validation-for="CreateRentalDto.ReturnDate" class="field-validation-error"></span>
                            </div>

                            <div class="col-md-12 mt-4 mb-4">
                                <h5 class="text-white border-bottom pb-2">Sürücü Bilgileri</h5>
                            </div>

                            <div class="col-md-6 mb-3">
                                <input type="text" asp-for="CreateRentalDto.Name" class="form-control custom-input" placeholder="Ad">
                                <span asp-validation-for="CreateRentalDto.Name" class="field-validation-error"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <input type="text" asp-for="CreateRentalDto.Surname" class="form-control custom-input" placeholder="Soyad">
                                <span asp-validation-for="CreateRentalDto.Surname" class="field-validation-error"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <input type="text" asp-for="CreateRentalDto.IdentityNumber" class="form-control custom-input" placeholder="T.C. Kimlik No">
                                <span asp-validation-for="CreateRentalDto.IdentityNumber" class="field-validation-error"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <input type="email" asp-for="CreateRentalDto.Email" class="form-control custom-input" placeholder="E-posta">
                                <span asp-validation-for="CreateRentalDto.Email" class="field-validation-error"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <input type="text" asp-for="CreateRentalDto.Phone" class="form-control custom-input" placeholder="Telefon (5xxxxxxxxx)">
                                <span asp-validation-for="CreateRentalDto.Phone" class="field-validation-error"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <input type="text" asp-for="CreateRentalDto.DrivingLicenseNumber" class="form-control custom-input" placeholder="Ehliyet Seri No">
                                <span asp-validation-for="CreateRentalDto.DrivingLicenseNumber" class="field-validation-error"></span>
                            </div>

                            <div class="col-md-12 mt-4">
                                <button type="submit" class="btn-main w-100 py-3">REZERVASYONU ONAYLA</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            <div class="col-lg-4">
                <div style="position: sticky; top: 100px;">
                    <div style="background: #1a1a1a; padding: 25px; border-radius: 12px; border: 1px solid rgba(255,255,255,0.08);">
                        <h4 class="text-white mb-4">Kiralama Özeti</h4>
                        <div class="d-flex align-items-center mb-4 pb-3" style="border-bottom: 1px solid rgba(255,255,255,0.1);">
                            <img src="@Model.CoverImageUrl" class="rounded" style="width: 100px; height: 70px; object-fit: cover;">
                            <div class="ms-3">
                                <h5 class="text-white mb-1">@Model.BrandName @Model.ModelName</h5>
                                <span class="badge bg-danger">@Model.PlateNumber</span>
                            </div>
                        </div>
                        <ul class="list-unstyled mb-0">
                            <li class="d-flex justify-content-between mb-3">
                                <span class="text-white-50">Günlük Fiyat:</span>
                                <span class="text-white">₺@Model.DailyPrice.ToString("N2")</span>
                            </li>
                            <li class="d-flex justify-content-between mb-3">
                                <span class="text-white-50">Süre:</span>
                                <span class="text-white" id="dayDisplay">— Gün</span>
                            </li>
                            <li class="d-flex justify-content-between mb-3">
                                <span class="text-white-50">Depozito (İade Edilir):</span>
                                <span class="text-white">₺@Model.DepositAmount.ToString("N2")</span>
                            </li>
                            <hr style="border-color: rgba(255,255,255,0.1);">
                            <li class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h5 class="text-white mb-0">Genel Toplam:</h5>
                                    <small class="text-white-50">(Kira + Depozito)</small>
                                </div>
                                <h4 class="id-color mb-0" id="totalDisplay">₺0.00</h4>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/tr.js"></script>

<script>
    // Fiyat ve Depozito verilerini C# -> JS aktarımı
    const dailyPrice = @Html.Raw(Model.DailyPrice.ToString(System.Globalization.CultureInfo.InvariantCulture));
    const depositAmount = @Html.Raw(Model.DepositAmount.ToString(System.Globalization.CultureInfo.InvariantCulture));

    // Flatpickr Ayarları
    const fpConfig = {
        locale: "tr",
        dateFormat: "d.m.Y",
        minDate: "today",
        disableMobile: true,
        onChange: function() {
            buildAndCalculate(); // Tarih her değiştiğinde hesapla
        }
    };

    const fpPickup = flatpickr("#pickUpDateUI", fpConfig);
    const fpReturn = flatpickr("#dropOffDateUI", fpConfig);

    // Saat seçimleri değiştiğinde de hesapla
    document.getElementById('pickUpTime').addEventListener('change', buildAndCalculate);
    document.getElementById('dropOffTime').addEventListener('change', buildAndCalculate);

    function buildAndCalculate() {
        const pdObj = fpPickup.selectedDates[0];
        const rdObj = fpReturn.selectedDates[0];
        const pHour = parseInt(document.getElementById('pickUpTime').value);
        const rHour = parseInt(document.getElementById('dropOffTime').value);

        // Alış Tarihi İşleme
        if (pdObj) {
            let pd = new Date(pdObj);
            pd.setHours(pHour, 0, 0, 0);
            // .NET'in anlayacağı formata (yyyy-MM-ddTHH:mm:ss) gizli inputa yazıyoruz
            document.getElementById('hdnPickupDate').value = toLocalISOString(pd);
            // Arayüzdeki "Alış: --" kısmını güncelle
            if(document.getElementById('pickupDisplay')) 
                document.getElementById('pickupDisplay').innerText = formatDisplay(pd);
        }

        // Dönüş Tarihi İşleme
        if (rdObj) {
            let rd = new Date(rdObj);
            rd.setHours(rHour, 0, 0, 0);
            document.getElementById('hdnReturnDate').value = toLocalISOString(rd);
            if(document.getElementById('returnDisplay')) 
                document.getElementById('returnDisplay').innerText = formatDisplay(rd);
        }

        calculate();
    }

function calculate() {
    const pVal = document.getElementById('hdnPickupDate').value;
    const rVal = document.getElementById('hdnReturnDate').value;
    
    if (!pVal || !rVal) return;

    const start = new Date(pVal);
    const end = new Date(rVal);
    
    const timeDiff = end.getTime() - start.getTime();
    const diffDays = Math.ceil(timeDiff / (1000 * 60 * 60 * 24));

    if (diffDays > 0) {
        const rentalFee = diffDays * dailyPrice;
        const grandTotal = rentalFee + depositAmount; // Toplam tutar (Kira + Depozito)

        document.getElementById('dayDisplay').innerText = diffDays + " Gün";
        document.getElementById('totalDisplay').innerText = "₺" + grandTotal.toLocaleString('tr-TR', { minimumFractionDigits: 2 });
        
        // Veritabanına gidecek olan gizli inputa GRAND TOTAL'i yazıyoruz
        document.getElementById('hdnTotalPrice').value = grandTotal.toFixed(2).replace('.', ',');
    } else {
        document.getElementById('dayDisplay').innerText = "— Gün";
        document.getElementById('totalDisplay').innerText = "₺" + depositAmount.toLocaleString('tr-TR', { minimumFractionDigits: 2 });
        document.getElementById('hdnTotalPrice').value = depositAmount.toFixed(2).replace('.', ',');
    }
}

    // Tarihi 'yyyy-MM-ddTHH:mm:ss' formatına çeviren yardımcı fonksiyon
    function toLocalISOString(date) {
        const tzo = -date.getTimezoneOffset(),
            dif = tzo >= 0 ? '+' : '-',
            pad = function(num) {
                return (num < 10 ? '0' : '') + num;
            };
        return date.getFullYear() +
            '-' + pad(date.getMonth() + 1) +
            '-' + pad(date.getDate()) +
            'T' + pad(date.getHours()) +
            ':' + pad(date.getMinutes()) +
            ':' + pad(date.getSeconds());
    }

    function formatDisplay(date) {
        return date.toLocaleDateString('tr-TR', { day: '2-digit', month: '2-digit', year: 'numeric' })
               + ' ' + pad(date.getHours()) + ':00';
    }

    function pad(n) { return n < 10 ? '0' + n : n; }
</script>
}