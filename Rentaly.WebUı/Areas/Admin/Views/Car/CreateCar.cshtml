@using Rentaly.EntityLayer.Entities
@model CreateCarDTO
@{
    ViewData["Title"] = "Araç Ekle";
    Layout = "/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

@section Styles {
    <style>
        .form-section {
            background: #1a1a1a;
            border: 1px solid var(--border);
            border-radius: var(--radius);
            box-shadow: var(--shadow-sm);
            margin-bottom: 20px;
            overflow: hidden;
            transition: var(--transition);
        }

            .form-section:hover {
                box-shadow: var(--shadow-md);
            }

        .section-header {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 18px 24px;
            border-bottom: 1px solid var(--border);
            background: #252525;
        }

        .section-icon {
            width: 38px;
            height: 38px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            flex-shrink: 0;
        }

        .section-title {
            font-family: 'Plus Jakarta Sans',sans-serif;
            font-size: 14.5px;
            font-weight: 700;
            color: var(--text-main);
            margin: 0;
        }

        .section-subtitle {
            font-size: 12px;
            color: var(--text-muted);
            margin: 0;
            margin-top: 1px;
        }

        .section-body {
            padding: 24px;
        }

        .form-label {
            font-size: 13px;
            font-weight: 600;
            color: var(--text-main);
            margin-bottom: 7px;
            display: flex;
            align-items: center;
            gap: 5px;
        }

            .form-label .required {
                color: var(--danger);
                font-size: 14px;
                line-height: 1;
            }

        .form-control, .form-select {
            font-family: 'DM Sans',sans-serif;
            font-size: 13.5px;
            color: #fff;
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            padding: 10px 14px;
            background: #2a2a2a;
            transition: var(--transition);
            outline: none;
            width: 100%;
        }

            .form-control:focus, .form-select:focus {
                border-color: var(--primary);
                box-shadow: 0 0 0 3px rgba(204,12,12,0.15);
            }

            .form-control::placeholder {
                color: #808080;
            }

            .form-control.is-invalid, .form-select.is-invalid {
                border-color: var(--danger);
            }

            .form-control.is-valid, .form-select.is-valid {
                border-color: var(--success);
            }

        .invalid-feedback {
            font-size: 12px;
            color: var(--danger);
            margin-top: 5px;
            display: none;
            align-items: center;
            gap: 4px;
        }

            .invalid-feedback.show {
                display: flex !important;
            }

        .form-hint {
            font-size: 12px;
            color: var(--text-muted);
            margin-top: 5px;
        }

        .input-icon-wrap {
            position: relative;
        }

            .input-icon-wrap .input-icon {
                position: absolute;
                left: 13px;
                top: 50%;
                transform: translateY(-50%);
                color: var(--text-muted);
                font-size: 14px;
                pointer-events: none;
            }

            .input-icon-wrap .form-control {
                padding-left: 38px;
            }

            .input-icon-wrap:focus-within .input-icon {
                color: var(--primary);
            }

        .input-suffix {
            position: absolute;
            right: 0;
            top: 0;
            bottom: 0;
            display: flex;
            align-items: center;
            padding: 0 14px;
            font-size: 13px;
            font-weight: 600;
            color: var(--text-muted);
            border-left: 1px solid var(--border);
            background: #2a2a2a;
            border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
            pointer-events: none;
        }

        .quick-add-row {
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .quick-add-row .form-select {
                flex: 1;
            }

        .btn-quick-add {
            flex-shrink: 0;
            width: 38px;
            height: 42px;
            border: 1.5px solid var(--primary);
            background: var(--primary-light);
            color: var(--primary);
            border-radius: var(--radius-sm);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            cursor: pointer;
            transition: var(--transition);
        }

            .btn-quick-add:hover {
                background: var(--primary);
                color: #fff;
            }

        .quick-modal-backdrop {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,.65);
            z-index: 9990;
            align-items: center;
            justify-content: center;
        }

            .quick-modal-backdrop.open {
                display: flex;
            }

        .quick-modal {
            background: #1a1a1a;
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 28px;
            width: 100%;
            max-width: 420px;
            box-shadow: 0 24px 60px rgba(0,0,0,.5);
            animation: modalIn .2s ease;
        }

        @@keyframes modalIn {
            from {
                opacity: 0;
                transform: translateY(-12px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .quick-modal-title {
            font-family: 'Plus Jakarta Sans',sans-serif;
            font-size: 16px;
            font-weight: 800;
            color: var(--text-main);
            margin-bottom: 18px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .quick-modal-title i {
                color: var(--primary);
            }

        .quick-modal-footer {
            display: flex;
            gap: 10px;
            justify-content: flex-end;
            margin-top: 20px;
        }

        .btn-modal-cancel {
            padding: 8px 18px;
            border: 1px solid var(--border);
            background: transparent;
            color: var(--text-muted);
            border-radius: var(--radius-sm);
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            transition: var(--transition);
        }

            .btn-modal-cancel:hover {
                background: #2a2a2a;
                color: var(--text-main);
            }

        .btn-modal-save {
            padding: 8px 22px;
            background: var(--primary);
            color: #fff;
            border: none;
            border-radius: var(--radius-sm);
            font-size: 13px;
            font-weight: 700;
            cursor: pointer;
            transition: var(--transition);
            display: flex;
            align-items: center;
            gap: 6px;
        }

            .btn-modal-save:hover {
                background: var(--primary-dark);
            }

            .btn-modal-save:disabled {
                opacity: .6;
                cursor: not-allowed;
            }

        .quick-modal-error {
            font-size: 12px;
            color: var(--danger);
            margin-top: 10px;
            display: none;
        }

        .fuel-options {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
        }

        .fuel-radio {
            display: none;
        }

            .fuel-radio + label {
                display: flex;
                align-items: center;
                gap: 7px;
                padding: 8px 16px;
                border: 1.5px solid var(--border);
                border-radius: 40px;
                font-size: 13px;
                font-weight: 600;
                color: var(--text-muted);
                cursor: pointer;
                transition: var(--transition);
                user-select: none;
            }

                .fuel-radio + label:hover {
                    border-color: var(--primary);
                    color: var(--primary);
                    background: var(--primary-light);
                }

            .fuel-radio:checked + label {
                border-color: var(--primary);
                background: var(--primary);
                color: #fff;
            }

        .counter-input {
            display: flex;
            align-items: center;
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            overflow: hidden;
            width: fit-content;
        }

        .counter-btn {
            width: 38px;
            height: 42px;
            border: none;
            background: #2a2a2a;
            color: var(--text-muted);
            font-size: 16px;
            cursor: pointer;
            transition: var(--transition);
            display: flex;
            align-items: center;
            justify-content: center;
        }

            .counter-btn:hover {
                background: var(--primary-light);
                color: var(--primary);
            }

        .counter-val {
            width: 52px;
            height: 42px;
            border: none;
            border-left: 1px solid var(--border);
            border-right: 1px solid var(--border);
            text-align: center;
            font-family: 'Plus Jakarta Sans',sans-serif;
            font-size: 15px;
            font-weight: 700;
            color: var(--text-main);
            outline: none;
            background: #1a1a1a;
        }

        .toggle-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 14px 0;
            border-bottom: 1px solid var(--border);
        }

            .toggle-row:last-child {
                border-bottom: none;
                padding-bottom: 0;
            }

            .toggle-row:first-child {
                padding-top: 0;
            }

        .toggle-label strong {
            font-size: 13.5px;
            font-weight: 600;
            color: var(--text-main);
            display: block;
        }

        .toggle-label span {
            font-size: 12px;
            color: var(--text-muted);
        }

        .form-switch .form-check-input {
            width: 44px;
            height: 24px;
            cursor: pointer;
            background-color: #3a3a3a;
            border-color: var(--border);
        }

            .form-switch .form-check-input:checked {
                background-color: var(--primary);
                border-color: var(--primary);
            }

        .upload-zone {
            border: 2px dashed var(--border);
            border-radius: var(--radius);
            padding: 32px 20px;
            text-align: center;
            cursor: pointer;
            transition: var(--transition);
            background: #252525;
            position: relative;
        }

            .upload-zone:hover, .upload-zone.dragover {
                border-color: var(--primary);
                background: var(--primary-light);
            }

            .upload-zone input[type="file"] {
                position: absolute;
                inset: 0;
                opacity: 0;
                cursor: pointer;
                width: 100%;
                height: 100%;
            }

        .upload-icon {
            width: 52px;
            height: 52px;
            background: var(--primary-light);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 12px;
            font-size: 20px;
            color: var(--primary);
            transition: var(--transition);
        }

        .upload-zone:hover .upload-icon {
            background: var(--primary);
            color: #fff;
        }

        .upload-title {
            font-family: 'Plus Jakarta Sans',sans-serif;
            font-size: 14px;
            font-weight: 700;
            color: var(--text-main);
            margin-bottom: 4px;
        }

        .upload-sub {
            font-size: 12.5px;
            color: var(--text-muted);
        }

        .img-tabs {
            display: flex;
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            overflow: hidden;
            margin-bottom: 14px;
        }

        .img-tab-btn {
            flex: 1;
            padding: 8px;
            font-size: 13px;
            font-weight: 600;
            font-family: 'DM Sans',sans-serif;
            border: none;
            cursor: pointer;
            transition: var(--transition);
        }

            .img-tab-btn.active {
                background: var(--primary);
                color: #fff;
            }

            .img-tab-btn:not(.active) {
                background: #2a2a2a;
                color: var(--text-muted);
            }

        .price-banner {
            background: linear-gradient(135deg,#7f0000,#cc0c0c);
            border-radius: var(--radius);
            padding: 16px 20px;
            color: #fff;
            display: none;
        }

        .sum-row {
            display: none;
            font-size: 13px;
            padding: 8px 0;
            border-bottom: 1px solid var(--border);
        }

            .sum-row:last-of-type {
                border-bottom: none;
            }

        .action-bar {
            position: sticky;
            bottom: 0;
            background: #1a1a1a;
            border-top: 1px solid var(--border);
            padding: 14px 0;
            margin-top: 4px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 10px;
            z-index: 100;
            box-shadow: 0 -4px 20px rgba(0,0,0,.2);
        }

        .btn-cancel-form {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            background: #1a1a1a;
            border: 1px solid var(--border);
            color: var(--text-muted);
            border-radius: var(--radius-sm);
            padding: 10px 20px;
            font-size: 13.5px;
            font-weight: 600;
            font-family: 'DM Sans',sans-serif;
            cursor: pointer;
            transition: var(--transition);
            text-decoration: none;
        }

            .btn-cancel-form:hover {
                background: #2a2a2a;
                color: var(--text-main);
            }

        .btn-submit-car {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: var(--primary);
            color: #fff;
            border: none;
            border-radius: var(--radius-sm);
            padding: 10px 24px;
            font-size: 13.5px;
            font-weight: 700;
            font-family: 'DM Sans',sans-serif;
            cursor: pointer;
            transition: var(--transition);
        }

            .btn-submit-car:hover {
                background: var(--primary-dark);
                box-shadow: 0 4px 14px rgba(204,12,12,0.4);
                transform: translateY(-1px);
            }

            .btn-submit-car:disabled {
                opacity: .7;
                cursor: not-allowed;
                transform: none;
            }

        .plate-preview {
            display: inline-flex;
            align-items: center;
            border: 2px solid #333;
            border-radius: 6px;
            overflow: hidden;
            margin-top: 10px;
        }

        .plate-flag {
            background: #003399;
            color: #FFD700;
            font-size: 9px;
            font-weight: 800;
            padding: 4px 6px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .plate-number {
            background: #f5f5f5;
            color: #111;
            font-size: 18px;
            font-weight: 900;
            padding: 4px 12px;
            letter-spacing: 3px;
            min-width: 110px;
            text-align: center;
        }

        .char-count {
            font-size: 11.5px;
            color: var(--text-muted);
            text-align: right;
            margin-top: 4px;
        }

        textarea.form-control {
            resize: vertical;
            min-height: 90px;
        }

        @@media (max-width:767px) {
            .section-body {
                padding: 14px;
            }

            .action-bar {
                padding: 12px 0;
            }
        }

        .current-image-remove {
            position: absolute;
            top: 8px;
            right: 8px;
            width: 28px;
            height: 28px;
            background: rgba(239,68,68,.85);
            border: none;
            border-radius: 50%;
            color: #fff;
            font-size: 13px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: var(--transition);
        }

            .current-image-remove:hover {
                background: var(--danger);
            }
    </style>
}

<div class="page-header">
    <div>
        <h1 class="page-title">Yeni Araç Ekle</h1>
        <p class="page-subtitle">Filoya yeni bir araç kaydı oluşturun.</p>
    </div>
    <a href="@Url.Action("CarList", "Car", new { area = "Admin" })" class="btn-cancel-form">
        <i class="fa-solid fa-arrow-left"></i> Listeye Dön
    </a>
</div>

<form id="carForm" asp-action="CreateCar" asp-controller="Car" asp-area="Admin"
      method="post" enctype="multipart/form-data" novalidate>
    @Html.AntiForgeryToken()

    <div class="row g-4">
        <div class="col-12 col-xl-8">

            @* Kimlik *@
            <div class="form-section">
                <div class="section-header">
                    <div class="section-icon" style="background:#2d0a0a;color:var(--primary);"><i class="fa-solid fa-id-card"></i></div>
                    <div><p class="section-title">Araç Kimlik Bilgileri</p><p class="section-subtitle">Plaka ve şasi numarası</p></div>
                </div>
                <div class="section-body">
                    <div class="row g-3">
                        <div class="col-12 col-md-6">
                            <label class="form-label" for="PlateNumber">Plaka <span class="required">*</span></label>
                            <div class="input-icon-wrap">
                                <input type="text" id="PlateNumber" name="PlateNumber" class="form-control"
                                       placeholder="34 ABC 123" maxlength="15" autocomplete="off"
                                       style="font-weight:700;letter-spacing:2px;font-family:'Plus Jakarta Sans',sans-serif;"
                                       oninput="this.value=this.value.toUpperCase();updatePlatePreview();validatePlateInput(this)" />
                                <i class="fa-solid fa-hashtag input-icon"></i>
                            </div>
                            <div class="invalid-feedback" id="plateError"><i class="fa-solid fa-circle-exclamation"></i> Plaka zorunludur.</div>
                            <div id="platePreviewWrap" style="display:none;margin-top:10px;">
                                <div class="plate-preview">
                                    <div class="plate-flag"><span>🇹🇷</span><small>TR</small></div>
                                    <div class="plate-number" id="platePreviewText">— — —</div>
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label" for="VIN">Şasi No (VIN) <span class="required">*</span></label>
                            <div class="input-icon-wrap">
                                <input type="text" id="VIN" name="VIN" class="form-control"
                                       placeholder="WBA5A5C5XED123456" maxlength="17" autocomplete="off"
                                       style="font-family:monospace;letter-spacing:1px;font-size:13px;"
                                       oninput="this.value=this.value.toUpperCase();updateVinCount();liveValidate(this)" />
                                <i class="fa-solid fa-barcode input-icon"></i>
                            </div>
                            <div class="d-flex justify-content-between mt-1">
                                <div class="invalid-feedback" id="vinError"><i class="fa-solid fa-circle-exclamation"></i> VIN zorunludur.</div>
                                <span asp-validation-for="VIN" class="invalid-feedback" style="display:flex;gap:4px;align-items:center;color:var(--danger);font-size:12px;margin-top:5px;"></span>
                                <div class="char-count ms-auto"><span id="vinCount">0</span>/17</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            @* Sınıflandırma *@
            <div class="form-section">
                <div class="section-header">
                    <div class="section-icon" style="background:#2d2d0a;color:var(--accent);"><i class="fa-solid fa-layer-group"></i></div>
                    <div><p class="section-title">Sınıflandırma</p><p class="section-subtitle">Bulunamayanı <strong style="color:var(--primary);">+</strong> ile hemen ekleyin</p></div>
                </div>
                <div class="section-body">
                    <div class="row g-3">
                        <div class="col-12 col-sm-6">
                            <label class="form-label" for="BrandId">Marka <span class="required">*</span></label>
                            <div class="quick-add-row">
                                <select id="BrandId" name="BrandId" class="form-select" onchange="loadModels(this.value);liveValidate(this);updateSummary()">
                                    <option value="">— Marka Seçin —</option>
                                    @foreach (var b in ViewBag.Brands as List<Brand> ?? new List<Brand>())
                                    {
                                        <option value="@b.BrandId">@b.BrandName</option>
                                    }
                                </select>
                                <button type="button" class="btn-quick-add" onclick="openModal('brand')" title="Yeni marka ekle"><i class="fa-solid fa-plus"></i></button>
                            </div>
                            <div class="invalid-feedback" id="brandError"><i class="fa-solid fa-circle-exclamation"></i> Marka seçimi zorunludur.</div>
                            <span asp-validation-for="BrandId" class="invalid-feedback" style="display:flex;gap:4px;align-items:center;color:var(--danger);font-size:12px;margin-top:5px;"></span>
                        </div>
                        <div class="col-12 col-sm-6">
                            <label class="form-label" for="CarModelId">Model <span class="required">*</span></label>
                            <div class="quick-add-row">
                                <select id="CarModelId" name="CarModelId" class="form-select" onchange="liveValidate(this);updateSummary()">
                                    <option value="">— Önce marka seçin —</option>
                                </select>
                                <button type="button" class="btn-quick-add" onclick="openModal('model')" title="Yeni model ekle"><i class="fa-solid fa-plus"></i></button>
                            </div>
                            <div class="invalid-feedback" id="modelError"><i class="fa-solid fa-circle-exclamation"></i> Model seçimi zorunludur.</div>
                            <span asp-validation-for="CategoryId" class="invalid-feedback" style="display:flex;gap:4px;align-items:center;color:var(--danger);font-size:12px;margin-top:5px;"></span>

                        </div>
                        <div class="col-12 col-sm-6">
                            <label class="form-label" for="CategoryId">Kategori <span class="required">*</span></label>
                            <div class="quick-add-row">
                                <select id="CategoryId" name="CategoryId" class="form-select" onchange="liveValidate(this)">
                                    <option value="">— Kategori Seçin —</option>
                                    @foreach (var c in ViewBag.Categories as List<Category> ?? new List<Category>())
                                    {
                                        <option value="@c.CategoryId">@c.CategoryName</option>
                                    }
                                </select>
                                <button type="button" class="btn-quick-add" onclick="openModal('category')" title="Yeni kategori ekle"><i class="fa-solid fa-plus"></i></button>
                            </div>
                            <div class="invalid-feedback" id="categoryError"><i class="fa-solid fa-circle-exclamation"></i> Kategori seçimi zorunludur.</div>
                            <span asp-validation-for="CategoryId" class="invalid-feedback" style="display:flex;gap:4px;align-items:center;color:var(--danger);font-size:12px;margin-top:5px;"></span>
                        </div>
                        <div class="col-12 col-sm-6">
                            <label class="form-label" for="BranchId">Şube <span class="required">*</span></label>
                            <div class="quick-add-row">
                                <select id="BranchId" name="BranchId" class="form-select" onchange="liveValidate(this)">
                                    <option value="">— Şube Seçin —</option>
                                    @foreach (var br in ViewBag.Branches as List<Branch> ?? new List<Branch>())
                                    {
                                        <option value="@br.BranchId">@br.BranchName - @br.City</option>
                                    }
                                </select>
                                <button type="button" class="btn-quick-add" onclick="openModal('branch')" title="Yeni şube ekle"><i class="fa-solid fa-plus"></i></button>
                            </div>
                            <div class="invalid-feedback" id="branchError"><i class="fa-solid fa-circle-exclamation"></i> Şube seçimi zorunludur.</div>
                            <span asp-validation-for="BranchId" class="invalid-feedback" style="display:flex;gap:4px;align-items:center;color:var(--danger);font-size:12px;margin-top:5px;"></span>
                        </div>
                    </div>
                </div>
            </div>

            @* Teknik *@
            <div class="form-section">
                <div class="section-header">
                    <div class="section-icon" style="background:#0a2d0a;color:#10b981;"><i class="fa-solid fa-screwdriver-wrench"></i></div>
                    <div><p class="section-title">Teknik Detaylar</p><p class="section-subtitle">Yıl, kilometre, yakıt ve koltuk</p></div>
                </div>
                <div class="section-body">
                    <div class="row g-3">
                        <div class="col-12 col-sm-6 col-md-4">
                            <label class="form-label" for="Year">Model Yılı <span class="required">*</span></label>
                            <div class="input-icon-wrap">
                                <input type="number" id="Year" name="Year" class="form-control" lang="en" placeholder="2024" min="1990" max="2030" oninput="liveValidate(this);updateSummary()" />
                                <i class="fa-solid fa-calendar input-icon"></i>
                            </div>
                            <div class="invalid-feedback" id="yearError"><i class="fa-solid fa-circle-exclamation"></i> Yıl zorunludur.</div>
                            <span asp-validation-for="Year" class="invalid-feedback" style="display:flex;gap:4px;align-items:center;color:var(--danger);font-size:12px;margin-top:5px;"></span>
                        </div>
                        <div class="col-12 col-sm-6 col-md-4">
                            <label class="form-label" for="Kilometer">Kilometre <span class="required">*</span></label>
                            <div class="input-icon-wrap" style="position:relative;">
                                <input type="number" id="Kilometer" name="Kilometer" class="form-control" lang="en" placeholder="0" min="0" style="padding-right:50px;" oninput="liveValidate(this)" />
                                <i class="fa-solid fa-road input-icon"></i>
                                <span class="input-suffix">km</span>
                            </div>
                            <div class="invalid-feedback" id="kmError"><i class="fa-solid fa-circle-exclamation"></i> Kilometre zorunludur.</div>
                            <span asp-validation-for="Kilometer" class="invalid-feedback" style="display:flex;gap:4px;align-items:center;color:var(--danger);font-size:12px;margin-top:5px;"></span>
                        </div>
                        <div class="col-12 col-sm-6 col-md-4">
                            <label class="form-label" for="Transmission">Vites <span class="required">*</span></label>
                            <select id="Transmission" name="Transmission" class="form-select" onchange="liveValidate(this);updateSummary()">
                                <option value="">— Seçin —</option>
                                <option value="Otomatik">Otomatik</option>
                                <option value="Manuel">Manuel</option>
                                <option value="Yarı Otomatik">Yarı Otomatik</option>
                                <option value="CVT">CVT</option>
                            </select>
                            <div class="invalid-feedback" id="transError"><i class="fa-solid fa-circle-exclamation"></i> Vites tipi zorunludur.</div>
                            <span asp-validation-for="Transmission" class="invalid-feedback" style="display:flex;gap:4px;align-items:center;color:var(--danger);font-size:12px;margin-top:5px;"></span>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Yakıt Tipi <span class="required">*</span></label>
                            <div class="fuel-options">
                                @foreach (var f in new[] { ("Benzin", "fa-gas-pump", "fuel_benzin"), ("Dizel", "fa-fill-drip", "fuel_dizel"), ("Elektrik", "fa-bolt", "fuel_elektrik"), ("Hibrit", "fa-leaf", "fuel_hibrit"), ("LPG", "fa-fire-flame-curved", "fuel_lpg") })
                                {
                                    <input type="radio" class="fuel-radio" name="FuelType" id="@f.Item3" value="@f.Item1" />
                                    <label for="@f.Item3"><i class="fa-solid @f.Item2"></i> @f.Item1</label>
                                }
                            </div>
                            <div class="invalid-feedback" id="fuelError"><i class="fa-solid fa-circle-exclamation"></i> Yakıt tipi zorunludur.</div>
                        </div>
                        <div class="col-12 col-sm-4">
                            <label class="form-label">Koltuk Sayısı <span class="required">*</span></label>
                            <div class="counter-input">
                                <button type="button" class="counter-btn" onclick="adjustCounter('SeatCount',-1)"><i class="fa-solid fa-minus"></i></button>
                                <input type="number" id="SeatCount" name="SeatCount" class="counter-val" value="5" min="1" max="20" readonly />
                                <button type="button" class="counter-btn" onclick="adjustCounter('SeatCount',1)"><i class="fa-solid fa-plus"></i></button>
                            </div>
                            <p class="form-hint"><i class="fa-solid fa-circle-info me-1" style="color:var(--primary);"></i>Sürücü dahil</p>
