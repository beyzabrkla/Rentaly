@section Scripts {
    <script>
        const _token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';

        function validatePlateNumber(plate) {
            // Türk plaka formatı: 34ABC123, 34 ABC 123, 34AB1234 vb.
            const cleaned = plate.replace(/\s/g, '');
            const regex = /^(0[1-9]|[1-7][0-9]|8[01])[A-Z]{1,3}[0-9]{2,4}$/;
            return regex.test(cleaned);
        }
        // MODAL
        function openModal(type) {
            if (type === 'model') {
                const brandId   = document.getElementById('BrandId').value;
                const brandText = document.getElementById('BrandId').options[document.getElementById('BrandId').selectedIndex]?.text;
                if (!brandId) { alert('Önce bir marka seçin, ardından model ekleyebilirsiniz.'); return; }
                document.getElementById('qModelBrandInfo').textContent = '🏷 ' + brandText;
            }
            clearModalInputs(type);
            document.getElementById(`modal-${type}`).classList.add('open');
            setTimeout(() => { document.querySelector(`#modal-${type} input[type="text"]`)?.focus(); }, 100);
        }

        function closeModal(type) {
            document.getElementById(`modal-${type}`).classList.remove('open');
            clearModalInputs(type);
        }

        function clearModalInputs(type) {
            const modal = document.getElementById(`modal-${type}`);
            modal.querySelectorAll('input[type="text"]').forEach(i => i.value = '');
            const errEl = document.getElementById(`q${cap(type)}Error`);
            if (errEl) { errEl.textContent = ''; errEl.style.display = 'none'; }
            const btn = document.getElementById(`q${cap(type)}SaveBtn`);
            if (btn) { btn.disabled = false; btn.innerHTML = '<i class="fa-solid fa-check"></i> Kaydet'; }
        }

        function cap(s) { return s.charAt(0).toUpperCase() + s.slice(1); }

        document.addEventListener('keydown', e => {
            if (e.key === 'Escape') document.querySelectorAll('.quick-modal-backdrop.open').forEach(m => m.classList.remove('open'));
        });
        document.querySelectorAll('.quick-modal-backdrop').forEach(b => {
            b.addEventListener('click', function(e) { if (e.target === this) this.classList.remove('open'); });
        });
        document.querySelectorAll('.quick-modal input').forEach(input => {
            input.addEventListener('keydown', e => { if (e.key === 'Enter') quickSave(input.closest('.quick-modal-backdrop').id.replace('modal-', '')); });
        });

        //QUICK SAVE
        async function quickSave(type) {
            const btn   = document.getElementById(`q${cap(type)}SaveBtn`);
            const errEl = document.getElementById(`q${cap(type)}Error`);
            errEl.style.display = 'none';
            btn.disabled = true;
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Kaydediliyor…';

            try {
                let url = '', body = `__RequestVerificationToken=${encodeURIComponent(_token)}`;

                if (type === 'brand') {
                    const name = document.getElementById('qBrandName').value.trim();
                    if (!name) { showModalError(type, 'Marka adı boş olamaz.'); return; }
                    url = '/Admin/Car/QuickAddBrand';
                    body += `&brandName=${encodeURIComponent(name)}`;
                } else if (type === 'model') {
                    const name    = document.getElementById('qModelName').value.trim();
                    const brandId = document.getElementById('BrandId').value;
                    if (!name) { showModalError(type, 'Model adı boş olamaz.'); return; }
                    url = '/Admin/Car/QuickAddModel';
                    body += `&modelName=${encodeURIComponent(name)}&brandId=${brandId}`;
                } else if (type === 'category') {
                    const name = document.getElementById('qCategoryName').value.trim();
                    if (!name) { showModalError(type, 'Kategori adı boş olamaz.'); return; }
                    url = '/Admin/Car/QuickAddCategory';
                    body += `&categoryName=${encodeURIComponent(name)}`;
                } else if (type === 'branch') {
                    const name    = document.getElementById('qBranchName').value.trim();
                    const city    = document.getElementById('qBranchCity').value.trim();
                    const address = document.getElementById('qBranchAddress').value.trim();
                    if (!name) { showModalError(type, 'Şube adı boş olamaz.'); return; }
                    if (!city) { showModalError(type, 'Şehir boş olamaz.'); return; }
                    url = '/Admin/Car/QuickAddBranch';
                    body += `&branchName=${encodeURIComponent(name)}&city=${encodeURIComponent(city)}&address=${encodeURIComponent(address)}`;
                }

                const res  = await fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body });
                const data = await res.json();

                if (!data.success) { showModalError(type, data.message ?? 'Bir hata oluştu.'); return; }

                addOptionToSelect(type, data.id, data.name);
                closeModal(type);
                if (type === 'brand') await loadModels(data.id);

            } catch (e) {
                showModalError(type, 'Sunucu hatası oluştu.');
            } finally {
                btn.disabled = false;
                btn.innerHTML = '<i class="fa-solid fa-check"></i> Kaydet';
            }
        }

        function showModalError(type, msg) {
            const errEl = document.getElementById(`q${cap(type)}Error`);
            errEl.textContent = msg; errEl.style.display = 'block';
            const btn = document.getElementById(`q${cap(type)}SaveBtn`);
            btn.disabled = false; btn.innerHTML = '<i class="fa-solid fa-check"></i> Kaydet';
        }

        function addOptionToSelect(type, id, name) {
            const map = { brand:'BrandId', model:'CarModelId', category:'CategoryId', branch:'BranchId' };
            const sel = document.getElementById(map[type]);
            if (!sel) return;
            const opt = document.createElement('option');
            opt.value = id; opt.textContent = name;
            sel.appendChild(opt);
            sel.value = id;
            sel.dispatchEvent(new Event('change'));
        }

        // MODEL AJAX
        async function loadModels(brandId) {
            const sel = document.getElementById('CarModelId');
            sel.innerHTML = '<option value="">Yükleniyor…</option>';
            if (!brandId) { sel.innerHTML = '<option value="">— Önce marka seçin —</option>'; return; }
            try {
                const res  = await fetch(`/Admin/Car/GetModelsByBrand?brandId=${brandId}`);
                const json = await res.json();
                sel.innerHTML = '<option value="">— Model Seçin —</option>';
                if (json.success && json.data?.length > 0) {
                    json.data.forEach(m => {
                        const opt = document.createElement('option');
                        opt.value       = m.id;
                        opt.textContent = m.name;
                        sel.appendChild(opt);
                    });
                } else {
                    sel.innerHTML = '<option value="">Bu markaya model yok — + ile ekleyin</option>';
                }
            } catch (e) { sel.innerHTML = '<option value="">Model yüklenemedi</option>'; }
            updateSummary();
        }

        //YARDIMCILAR
        function updatePlatePreview() {
            const val = document.getElementById('PlateNumber').value.trim();
            document.getElementById('platePreviewWrap').style.display = val.length >= 2 ? 'block' : 'none';
            document.getElementById('platePreviewText').textContent = val || '— — —';
            updateSummary();
        }

        function validatePlateInput(el) {
            const val = el.value.trim();
            const errEl = document.getElementById('plateError');
            if (!val) {
                el.classList.add('is-invalid');
                el.classList.remove('is-valid');
                errEl.innerHTML = '<i class="fa-solid fa-circle-exclamation"></i> Plaka zorunludur.';
                errEl.style.display = 'flex';
            } else if (!validatePlateNumber(val)) {
                el.classList.add('is-invalid');
                el.classList.remove('is-valid');
                errEl.innerHTML = '<i class="fa-solid fa-circle-exclamation"></i> Geçerli bir plaka giriniz. (Örn: 34 ABC 123)';
                errEl.style.display = 'flex';
            } else {
                el.classList.remove('is-invalid');
                el.classList.add('is-valid');
                errEl.style.display = 'none';
            }
            updateSummary();
        }

        function updateVinCount() { document.getElementById('vinCount').textContent = document.getElementById('VIN').value.length; }

        function adjustCounter(id, delta) {
            const el = document.getElementById(id);
            el.value = Math.max(parseInt(el.min)||0, Math.min(parseInt(el.max)||99, parseInt(el.value)+delta));
        }

        function updatePriceBanner() {
            const daily = parseFloat(document.getElementById('DailyPrice').value) || 0;
            const dep   = parseFloat(document.getElementById('DepositAmount').value) || 0;
            const b     = document.getElementById('priceBanner');
            if (daily > 0) {
                b.style.display = 'block';
                document.getElementById('bannerDaily').textContent   = '₺' + daily.toLocaleString('tr-TR');
                document.getElementById('bannerWeekly').textContent  = '₺' + (daily*7).toLocaleString('tr-TR');
                document.getElementById('bannerMonthly').textContent = '₺' + (daily*30).toLocaleString('tr-TR');
                document.getElementById('bannerDeposit').textContent = dep > 0 ? '₺'+dep.toLocaleString('tr-TR') : '—';
            } else { b.style.display = 'none'; }
        }

        function updateSummary() {
            const plate = document.getElementById('PlateNumber').value;
            const bSel  = document.getElementById('BrandId');
            const mSel  = document.getElementById('CarModelId');
            const year  = document.getElementById('Year').value;
            const fuel  = document.querySelector('input[name="FuelType"]:checked')?.value || '';
            const trans = document.getElementById('Transmission').value;
            const price = document.getElementById('DailyPrice').value;
            let hasAny  = false;
            function setRow(rId, vId, show, txt) {
                document.getElementById(rId).style.display = show ? 'block' : 'none';
                if (show) { document.getElementById(vId).textContent = txt; hasAny = true; }
            }
            setRow('sumPlate','sumPlateVal', !!plate, plate);
            setRow('sumBrand','sumBrandVal', !!(bSel.value && mSel.value), `${bSel.options[bSel.selectedIndex]?.text} ${mSel.options[mSel.selectedIndex]?.text}`);
            setRow('sumYear', 'sumYearVal',  !!year, year);
            setRow('sumFuel', 'sumFuelVal',  !!(fuel||trans), [fuel,trans].filter(Boolean).join(' / '));
            setRow('sumPrice','sumPriceVal', !!price, `₺${parseFloat(price||0).toLocaleString('tr-TR')} / gün`);
            document.getElementById('sumEmpty').style.display = hasAny ? 'none' : 'block';
        }

        function liveValidate(el) {
            el.classList.toggle('is-invalid', !el.value || el.value === '');
            el.classList.toggle('is-valid',   !!(el.value && el.value !== ''));
            updateSummary();
        }

        // KAPAK GÖRSELİ - DOSYA + LINK DESTEĞİ (EditCar stili)
        function switchImageTab(tab, event) {
            document.querySelectorAll('.image-tab-content').forEach(el => el.style.display = 'none');
            document.getElementById(tab + 'Tab').style.display = 'block';

            document.querySelectorAll('.img-tab-btn').forEach(btn => {
                btn.classList.remove('active');
            });

            const activeBtn = event?.target?.closest('.img-tab-btn');
            if (activeBtn) activeBtn.classList.add('active');
        }

        // Kapak — Dosya seçme
        function handleFileSelect(event) {
            const file = event.target.files[0];
            if (!file) return;
            if (!file.type.startsWith('image/')) { alert('Lütfen bir görsel dosyası seçiniz.'); return; }
            if (file.size > 5 * 1024 * 1024) { alert('Dosya boyutu 5MB\'dan büyük olamaz.'); return; }

            const reader = new FileReader();
            reader.onload = function(e) {
                document.getElementById('newImgPreview').src = e.target.result;
                document.getElementById('newImgFileName').textContent = file.name + ' (' + (file.size / 1024).toFixed(0) + ' KB)';
                document.getElementById('newImgPreviewWrap').style.display = 'block';
                document.getElementById('ImageSourceType').value = 'file';
            };
            reader.readAsDataURL(file);
        }

        function clearNewImage() {
            document.getElementById('imageFile').value = '';
            document.getElementById('newImgPreviewWrap').style.display = 'none';
            document.getElementById('ImageSourceType').value = '';
        }

        // Kapak — Drag & Drop
        function handleDragOver(e) {
            e.preventDefault();
            document.getElementById('uploadZone').style.borderColor = 'var(--primary)';
            document.getElementById('uploadZone').style.backgroundColor = 'var(--primary-light)';
        }
        function handleDragLeave(e) {
            e.preventDefault();
            document.getElementById('uploadZone').style.borderColor = 'var(--border)';
            document.getElementById('uploadZone').style.backgroundColor = '#252525';
        }
        function handleDrop(e) {
            e.preventDefault();
            document.getElementById('uploadZone').style.borderColor = 'var(--border)';
            document.getElementById('uploadZone').style.backgroundColor = '#252525';
            const files = e.dataTransfer.files;
            if (files.length > 0) {
                document.getElementById('imageFile').files = files;
                handleFileSelect({ target: { files: files } });
            }
        }

        // Kapak — URL
        function previewUrlImage(url) {
            if (!url.trim()) {
                document.getElementById('urlImgPreviewWrap').style.display = 'none';
                document.getElementById('CoverImageUrl').value = '';
                document.getElementById('ImageSourceType').value = '';
                return;
            }
            try { new URL(url); } catch(e) { document.getElementById('urlImgPreviewWrap').style.display = 'none'; return; }

            const img = new Image();
            img.onload = function() {
                document.getElementById('urlImgPreview').src = url;
                document.getElementById('urlImgPreviewWrap').style.display = 'block';
                document.getElementById('CoverImageUrl').value = url;
                document.getElementById('ImageSourceType').value = 'url';
                document.getElementById('urlImgStatus').innerHTML = '<i class="fa-solid fa-check me-1"></i>Başarılı';
            };
            img.onerror = function() {
                document.getElementById('urlImgStatus').innerHTML = '<i class="fa-solid fa-exclamation me-1" style="color:#ef4444;"></i>Yüklenemedi';
                document.getElementById('urlImgPreviewWrap').style.display = 'block';
            };
            img.src = url;
        }

        function clearUrlImage() {
            document.getElementById('CoverImageUrlInput').value = '';
            document.getElementById('urlImgPreviewWrap').style.display = 'none';
            document.getElementById('CoverImageUrl').value = '';
            document.getElementById('ImageSourceType').value = '';
        }

        // DİĞER GÖRSELLER - ÇOKLU YÖNETİMİ (EditCar stili)
        function handleMultipleFileSelect(event) {
            const files = Array.from(event.target.files);
            if (!files.length) return;
            const validFiles = files.filter(f => {
                if (!f.type.startsWith('image/')) { alert(f.name + ' bir görsel değil.'); return false; }
                if (f.size > 5 * 1024 * 1024) { alert(f.name + ' 5MB\'dan büyük.'); return false; }
                return true;
            });
            displayMultipleImagePreviews(validFiles);
        }

        function displayMultipleImagePreviews(files) {
            const container = document.getElementById('newImagesPreviewGrid');
            container.innerHTML = '';
            files.forEach(file => {
                const reader = new FileReader();
                reader.onload = function(e) {
                    const div = document.createElement('div');
                    div.className = 'new-image-item';
                    div.style.cssText = 'position:relative;border-radius:8px;overflow:hidden;border:1px solid var(--border);height:120px;';
                    div.innerHTML = `
                        <img src="${e.target.result}" style="width:100%;height:100%;object-fit:cover;" />
                        <button type="button" onclick="removeImagePreview(this)"
                                style="position:absolute;top:4px;right:4px;width:24px;height:24px;border-radius:50%;background:rgba(239,68,68,0.9);color:white;border:none;cursor:pointer;font-size:12px;display:flex;align-items:center;justify-content:center;">
                            <i class="fa-solid fa-xmark"></i>
                        </button>`;
                    container.appendChild(div);
                };
                reader.readAsDataURL(file);
            });
            document.getElementById('multipleImgPreviewWrap').style.display = 'block';
            document.getElementById('newImagesCount').textContent = files.length;
        }

        function removeImagePreview(btn) {
            btn.closest('.new-image-item').remove();
            const remaining = document.querySelectorAll('.new-image-item').length;
            if (remaining === 0) {
                document.getElementById('carImageFiles').value = '';
                document.getElementById('multipleImgPreviewWrap').style.display = 'none';
            } else {
                document.getElementById('newImagesCount').textContent = remaining;
            }
        }

        function clearMultipleNewImages() {
            document.getElementById('carImageFiles').value = '';
            document.getElementById('newImagesPreviewGrid').innerHTML = '';
            document.getElementById('multipleImgPreviewWrap').style.display = 'none';
        }

        // Çoklu — Drag & Drop
        function handleMultipleDragOver(e) {
            e.preventDefault();
            document.getElementById('multipleUploadZone').style.borderColor = 'var(--primary)';
            document.getElementById('multipleUploadZone').style.backgroundColor = 'rgba(20,184,166,0.05)';
        }
        function handleMultipleDragLeave(e) {
            e.preventDefault();
            document.getElementById('multipleUploadZone').style.borderColor = 'var(--border)';
            document.getElementById('multipleUploadZone').style.backgroundColor = '#252525';
        }
        function handleMultipleDrop(e) {
            e.preventDefault();
            document.getElementById('multipleUploadZone').style.borderColor = 'var(--border)';
            document.getElementById('multipleUploadZone').style.backgroundColor = '#252525';
            const files = Array.from(e.dataTransfer.files).filter(f => f.type.startsWith('image/') && f.size <= 5*1024*1024);
            displayMultipleImagePreviews(files);
        }

        // YAKÎT TİPİ
        document.querySelectorAll('input[name="FuelType"]').forEach(r => {
            r.addEventListener('change', () => { document.getElementById('fuelError').classList.remove('show'); updateSummary(); });
        });

        // FORM SUBMIT
        document.getElementById('carForm').addEventListener('submit', function(e) {
            const required = ['PlateNumber','VIN','BrandId','CarModelId','CategoryId','BranchId','Year','Kilometer','DailyPrice','DepositAmount','Transmission'];
            let valid = true;

            required.forEach(id => {
                const el = document.getElementById(id);
                if (!el || !el.value || el.value === '') { el?.classList.add('is-invalid'); valid = false; }
                else { el.classList.remove('is-invalid'); el.classList.add('is-valid'); }
            });

            // Plaka format kontrolü
            const plateEl  = document.getElementById('PlateNumber');
            const plateErr = document.getElementById('plateError');
            if (plateEl.value && !validatePlateNumber(plateEl.value)) {
                plateEl.classList.add('is-invalid');
                plateEl.classList.remove('is-valid');
                plateErr.innerHTML = '<i class="fa-solid fa-circle-exclamation"></i> Geçerli bir plaka giriniz. (Örn: 34 ABC 123)';
                plateErr.style.display = 'flex';
                valid = false;
            }

            const fuel    = document.querySelector('input[name="FuelType"]:checked');
            const fuelErr = document.getElementById('fuelError');
            if (!fuel) { fuelErr.classList.add('show'); valid = false; }
            else        { fuelErr.classList.remove('show'); }

            // ImageSourceType: URL girilmişse ama type boşsa tamamla
            if (!document.getElementById('ImageSourceType').value && document.getElementById('CoverImageUrl').value) {
                document.getElementById('ImageSourceType').value = 'url';
            }

            if (!valid) {
                e.preventDefault();
                document.querySelector('.is-invalid')?.scrollIntoView({ behavior: 'smooth', block: 'center' });
                return;
            }

            const btn     = document.getElementById('submitBtn');
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Kaydediliyor…';
            btn.disabled  = true;
        });

        // SAYFA YÜKLEME
        document.addEventListener('DOMContentLoaded', () => {
            // Kapak görseli upload zone tıklanabilir
            document.getElementById('uploadZone')?.addEventListener('click', () => {
                document.getElementById('imageFile').click();
            });

            // Çoklu görsel upload zone tıklanabilir
            document.getElementById('multipleUploadZone')?.addEventListener('click', () => {
                document.getElementById('carImageFiles').click();
            });
        });
    </script>
}


