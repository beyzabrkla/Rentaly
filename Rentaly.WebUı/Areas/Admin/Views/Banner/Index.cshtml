@model List<Banner>
@{
    ViewData["Title"] = "Banner Yönetimi";
    Layout = "/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Banner Yönetimi</h1>
        <p class="page-subtitle">Anasayfa giriş ekranındaki başlık ve görselleri düzenleyin.</p>
    </div>
</div>

<div class="row g-4">
    @foreach (var item in Model)
    {
        <div class="col-12 col-xl-6">
            <div class="vehicle-card" style="height: 100%;">
                <div style="height:150px; overflow:hidden; border-radius:12px 12px 0 0; position:relative;">
                    <img src="@item.BackgroundImageUrl" style="width:100%; height:100%; object-fit:cover; opacity:0.6;" />
                    <div style="position:absolute; bottom:15px; left:20px;">
                        <span class="badge bg-danger">Aktif Banner</span>
                    </div>
                </div>

                <div class="vehicle-body">
                    <div class="vehicle-brand">#@item.BannerId</div>
                    <div class="vehicle-name">@item.Title</div>
                    <div style="color:var(--text-muted); font-size:13px; margin-bottom:15px;">@item.SubTitle</div>

                    <div class="mt-2 p-3" style="background: rgba(255,255,255,0.03); border-radius: 8px; font-size: 13px; color: var(--text-muted);">
                        @item.Description
                    </div>
                </div>

                <div class="vehicle-actions">
                    <a href="/Admin/Banner/UpdateBanner/@item.BannerId" class="btn-action btn-detail" style="text-decoration:none; justify-content:center;">
                        <i class="fa-solid fa-pen-to-square"></i> Düzenle
                    </a>
                </div>
            </div>
        </div>
    }
</div>