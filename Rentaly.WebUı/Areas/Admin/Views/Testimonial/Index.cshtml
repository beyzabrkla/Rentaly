@model List<Testimonial>
@{
    ViewData["Title"] = "Müşteri Yorumları";
    Layout = "/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .testimonial-img {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        object-fit: cover;
        border: 2px solid #cc0c0c;
    }
    .comment-text {
        font-style: italic;
        color: #d1d1d1 !important;
        margin-top: 15px;
        font-size: 14px;
    }
</style>

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h1 class="page-title">Müşteri Yorumları</h1>
        <p class="page-subtitle">Müşterilerinizin geri bildirimlerini yönetin.</p>
    </div>
    <a href="/Admin/Testimonial/CreateTestimonial" class="btn-action btn-delete" style="text-decoration:none; flex:none; padding: 12px 25px;">
        <i class="fa-solid fa-plus-circle"></i> Yeni Yorum Ekle
    </a>
</div>

<div class="row g-4">
    @foreach (var item in Model)
    {
        <div class="col-12 col-md-6 col-xl-4">
            <div class="vehicle-card" style="height: 100%;">
                <div class="vehicle-body">
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "/RentalyHTML/images/testimonial/default.jpg" : item.ImageUrl)" class="testimonial-img" />
                        <div>
                            <div class="vehicle-name" style="margin-bottom:0;">@item.Name</div>
                            <small class="text-danger" style="font-weight:600; font-size:12px;">@item.Title</small>
                        </div>
                    </div>
                    <p class="comment-text">
                        <i class="fa-solid fa-quote-left me-2 text-muted"></i>
                        @item.Comment
                    </p>
                </div>

                <div class="vehicle-actions">
                    <a href="/Admin/Testimonial/UpdateTestimonial/@item.TestimonialId" class="btn-action btn-detail" style="text-decoration:none; justify-content:center;">
                        <i class="fa-solid fa-pen"></i> Düzenle
                    </a>
                    <a href="/Admin/Testimonial/DeleteTestimonial/@item.TestimonialId" class="btn-action btn-delete" style="text-decoration:none; justify-content:center;" onclick="return confirm('Yorumu silmek istediğinize emin misiniz?')">
                        <i class="fa-solid fa-trash"></i> Sil
                    </a>
                </div>
            </div>
        </div>
    }
</div>