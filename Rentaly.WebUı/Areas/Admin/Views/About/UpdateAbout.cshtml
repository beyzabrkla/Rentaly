@model About
@{
    ViewData["Title"] = "Hakkımızda Güncelle";
    Layout = "/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header">
    <div>
        <h1 class="page-title">İçeriği Düzenle</h1>
        <p class="page-subtitle">Hakkımızda bilgilerini ve görselini güncelleyin.</p>
    </div>
</div>

<div class="toolbar-card" style="display: block; padding: 30px;">
    <form method="post">
        <input type="hidden" asp-for="AboutId" />

        <div class="row g-4">
            <div class="col-md-6">
                <label class="form-label" style="color:var(--text-muted); font-size:12px; font-weight:700; text-transform:uppercase;">Ana Başlık</label>
                <div class="search-wrap" style="width:100%;">
                    <i class="fa-solid fa-heading"></i>
                    <input type="text" asp-for="Title" placeholder="Ana başlığı girin..." />
                </div>
            </div>

            <div class="col-md-6">
                <label class="form-label" style="color:var(--text-muted); font-size:12px; font-weight:700; text-transform:uppercase;">Alt Başlık</label>
                <div class="search-wrap" style="width:100%;">
                    <i class="fa-solid fa-paragraph"></i>
                    <input type="text" asp-for="SubTitle" placeholder="Kısa bir alt başlık..." />
                </div>
            </div>

            <div class="col-12">
                <label class="form-label" style="color:var(--text-muted); font-size:12px; font-weight:700; text-transform:uppercase;">Açıklama Metni</label>
                <textarea asp-for="Description" class="form-control" rows="6"
                          style="background:var(--bg-main); border:1px solid var(--border); color:var(--text-main); border-radius:12px; padding:15px; width:100%; outline:none;"></textarea>
            </div>

            <div class="col-12">
                <label class="form-label" style="color:var(--text-muted); font-size:12px; font-weight:700; text-transform:uppercase;">Görsel URL</label>
                <div class="search-wrap" style="width:100%;">
                    <i class="fa-solid fa-image"></i>
                    <input type="text" asp-for="ImageUrl" placeholder="Görsel linkini yapıştırın..." />
                </div>
            </div>

            @* İstatistikler *@
            <div class="col-md-4">
                <label class="form-label" style="color:var(--text-muted); font-size:12px; font-weight:700; text-transform:uppercase;">Deneyim Yılı</label>
                <div class="search-wrap" style="width:100%;">
                    <i class="fa-solid fa-award"></i>
                    <input type="text" asp-for="ExperienceYear" placeholder="Örn: 15+" />
                </div>
            </div>
            <div class="col-md-4">
                <label class="form-label" style="color:var(--text-muted); font-size:12px; font-weight:700; text-transform:uppercase;">Araç Sayısı</label>
                <div class="search-wrap" style="width:100%;">
                    <i class="fa-solid fa-car-side"></i>
                    <input type="number" asp-for="CarCount" />
                </div>
            </div>
            <div class="col-md-4">
                <label class="form-label" style="color:var(--text-muted); font-size:12px; font-weight:700; text-transform:uppercase;">Mutlu Müşteri</label>
                <div class="search-wrap" style="width:100%;">
                    <i class="fa-solid fa-users"></i>
                    <input type="number" asp-for="HappyCustomerCount" />
                </div>
            </div>
        </div>

        <div class="mt-5 d-flex gap-3">
            <button type="submit" class="btn-action btn-delete" style="padding: 12px 40px; flex: none;">
                <i class="fa-solid fa-check"></i> Değişiklikleri Kaydet
            </button>
            <a href="/Admin/About/Index" class="btn-action btn-detail" style="padding: 12px 30px; flex: none; text-decoration:none;">
                Vazgeç
            </a>
        </div>
    </form>
</div>

<style>
    /* Textarea Focus Efekti */
    textarea:focus {
        border-color: var(--primary) !important;
    }
</style>