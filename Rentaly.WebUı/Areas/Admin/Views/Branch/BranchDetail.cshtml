@using Microsoft.AspNetCore.WebUtilities
@model List<ResultCarDTO>
@{
    var branch = ViewBag.Branch as Branch;
    ViewData["Title"] = branch?.BranchName + " Araçları";
    Layout = "/Areas/Admin/Views/Shared/_AdminLayout.cshtml";

    var queryParams = QueryHelpers.ParseQuery(Context.Request.QueryString.Value);
    var filterParams = new Dictionary<string, string>();
    
    foreach (var param in queryParams)
    {
        if (param.Key.ToLower() != "page") filterParams[param.Key] = param.Value.ToString();
    }

    string GetPageUrl(int n)
    {
        var qs = new Dictionary<string, string>(filterParams) { ["page"] = n.ToString() };
        return Url.Action("BranchDetail", "Branch", new { area = "Admin" }) + QueryString.Create(qs).Value;
    }
}

<div class="page-header">
    <div class="d-flex align-items-center gap-3">
        <a href="@Url.Action("BranchList", "Branch", new { area = "Admin" })"
               class="btn-action btn-detail"
               style="width:45px; height:45px; border-radius:50%; flex:none; display:flex; align-items:center; justify-content:center;">
            <i class="fa-solid fa-arrow-left m-0"></i>
        </a>
        <div>
            <h1 class="page-title" style="color:#ffffff;">@branch?.BranchName - Araçlar</h1>
            <p class="page-subtitle">@branch?.City şubesindeki aktif filo listesi.</p>
        </div>
    </div>
</div>

@* Stat Kartları *@
<div class="row g-3 mb-4">
    <div class="col-6 col-md-4">
        <div class="stat-card text-center py-3">
            <div style="font-family:'Plus Jakarta Sans'; font-size:24px; font-weight:800; color:#ffffff;">@ViewBag.TotalCars</div>
            <div style="font-size:12px; color:var(--text-muted);">Toplam Araç</div>
        </div>
    </div>
    <div class="col-6 col-md-4">
        <div class="stat-card text-center py-3">
            <div style="font-family:'Plus Jakarta Sans'; font-size:24px; font-weight:800; color:#10b981;">@ViewBag.AvailableCount</div>
            <div style="font-size:12px; color:var(--text-muted);">Müsait</div>
        </div>
    </div>
    <div class="col-12 col-md-4">
        <div class="stat-card text-center py-3">
            <div style="font-family:'Plus Jakarta Sans'; font-size:24px; font-weight:800; color:var(--accent);">@ViewBag.RentedCount</div>
            <div style="font-size:12px; color:var(--text-muted);">Kirada</div>
        </div>
    </div>
</div>

@* Araç Listesi *@
<div class="row g-4">
    @if (Model == null || !Model.Any())
    {
        <div class="col-12 text-center py-5">
            <div style="color:var(--text-muted); opacity:0.5;">
                <i class="fa-solid fa-car" style="font-size:48px; display:block; margin-bottom:16px;"></i>
                <p style="font-size:15px;">Bu şubede henüz kriterlere uygun araç bulunmuyor.</p>
            </div>
        </div>
    }
    else
    {
        @foreach (var car in Model)
        {
            <div class="col-12 col-sm-6 col-xl-4">
                <div class="vehicle-card h-100">
                    <div class="vehicle-img-wrap">
                        <img src="@(string.IsNullOrEmpty(car.CoverImageUrl) ? "https://placehold.co/600x340/1a1a1a/555?text=Foto+Yok" : car.CoverImageUrl)"
                             alt="@car.CarModelName" />
                        <span class="vehicle-status @(car.IsAvailable ? "status-available" : "status-rented")">
                            <i class="fa-solid @(car.IsAvailable ? "fa-circle-check" : "fa-circle-dot") me-1"></i>
                            @(car.IsAvailable ? "Müsait" : "Kirada")
                        </span>
                    </div>

                    <div class="vehicle-body">
                        <div class="vehicle-brand">@car.BrandName</div>
                        <div class="vehicle-name">@car.CarModelName</div>

                        <div class="vehicle-specs">
                            <div class="spec-item"><i class="fa-solid fa-road"></i> <span>@car.Kilometer.ToString("N0") km</span></div>
                            <div class="spec-item"><i class="fa-solid fa-gears"></i> <span>@car.Transmission</span></div>
                        </div>

                        <div class="vehicle-price-row mt-3">
                            <div class="vehicle-price">
                                <span class="price-amount">₺@car.DailyPrice.ToString("N0")</span>
                                <span class="price-label">/ gün</span>
                            </div>
                            <span class="vehicle-year-badge">@car.Year</span>
                        </div>
                    </div>

                    <div class="vehicle-actions">
                        <a href="/Admin/Car/EditCar/@car.CarId" class="btn-action btn-edit">
                            <i class="fa-solid fa-pen-to-square"></i> Düzenle
                        </a>
                    </div>
                </div>
            </div>
        }
    }
</div>

@* Sayfalama *@
@if ((int)ViewBag.TotalPages > 1)
{
    <div class="row mt-5">
        <div class="col-12">
            <nav style="display:flex;justify-content:center;align-items:center;gap:8px;flex-wrap:wrap;">
                @if ((int)ViewBag.CurrentPage > 1)
                {
                    <a href="@GetPageUrl(1)" class="btn-action btn-detail" style="flex:unset;padding:8px 14px;"><i class="fa-solid fa-angles-left"></i> İlk</a>
                    <a href="@GetPageUrl((int)ViewBag.CurrentPage - 1)" class="btn-action btn-detail" style="flex:unset;padding:8px 14px;"><i class="fa-solid fa-angle-left"></i> Önceki</a>
                }
                
                <div style="display:flex;gap:6px;">
                    @{
                        int start = Math.Max(1, (int)ViewBag.CurrentPage - 2);
                        int end = Math.Min((int)ViewBag.TotalPages, (int)ViewBag.CurrentPage + 2);
                    }
                    @for (int i = start; i <= end; i++)
                    {
                        if (i == (int)ViewBag.CurrentPage)
                        {
                            <span class="btn-action btn-delete" style="flex:unset;padding:8px 14px;">@i</span>
                        }
                        else
                        {
                            <a href="@GetPageUrl(i)" class="btn-action btn-detail" style="flex:unset;padding:8px 14px;">@i</a>
                        }
                    }
                </div>

                @if ((int)ViewBag.CurrentPage < (int)ViewBag.TotalPages)
                {
                    <a href="@GetPageUrl((int)ViewBag.CurrentPage + 1)" class="btn-action btn-detail" style="flex:unset;padding:8px 14px;">Sonraki <i class="fa-solid fa-angle-right"></i></a>
                    <a href="@GetPageUrl((int)ViewBag.TotalPages)" class="btn-action btn-detail" style="flex:unset;padding:8px 14px;">Son <i class="fa-solid fa-angles-right"></i></a>
                }
            </nav>
        </div>
    </div>
}